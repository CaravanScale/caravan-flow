// ProcessorGroup — owns workers, wiring, and lifecycle.

import core
import fmt

class ProcessorGroup {
    String name
    var workers = Map<String, ProcessorWorker>{}
    var processorFns = Map<String, core.ProcessorFn>{}
    var order = List<String>[]

    init(String name) {
        this.name = name
    }

    pub fn addProcessor(String procName, core.ProcessorFn processor) {
        workers[procName] = ProcessorWorker(procName)
        processorFns[procName] = processor
        order = append(order, procName)
    }

    pub fn connect(String fromName, String toName) {
        var source = workers[fromName]
        var target = workers[toName]
        source.output = target.input
    }

    pub fn start() {
        for wn in order {
            workers[wn].start(processorFns[wn])
        }
    }

    pub fn stop() {
        for wn in order {
            workers[wn].stop()
        }
    }

    pub fn swapProcessor(String procName, core.ProcessorFn newFn) {
        var w = workers[procName]
        w.stop()
        processorFns[procName] = newFn
        w.start(newFn)
    }

    pub fn getInput(String procName): Channel<core.FlowFile> {
        return workers[procName].input
    }

    pub fn getOutput(String procName): Channel<core.FlowFile> {
        return workers[procName].output
    }

    pub fn status() {
        fmt.Println("Group: {name}")
        for wn in order {
            fmt.Println("  {workers[wn].stats()}")
        }
    }
}
