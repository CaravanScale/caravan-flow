// ProcessorResult — sealed return type for all processors.
// The worker loop pattern-matches on this to route FlowFiles.

sealed class ProcessorResult {
    data Single(FlowFile ff)
    data Multiple(List<FlowFile> ffs)
    data Routed(String route, FlowFile ff)
    data Drop()
}

// ProcessorFn — functional interface for processor implementations.
// Lambdas and method references satisfy this interface.

interface ProcessorFn {
    fn process(FlowFile ff): ProcessorResult
}
