// Management API — REST endpoints for monitoring and controlling zinc-flow.
// All responses are JSON. Mounted under /api/ in main.zn.

import net.http
import io
import encoding.json
import core
import fabric.runtime
import fabric.registry
import fabric.router

// ApiHandler holds a reference to the fabric for serving API requests.
class ApiHandler {
    Fabric fab

    init(Fabric fab) {
        this.fab = fab
    }

    // GET /api/stats — aggregate processing statistics
    pub fn statsHandler(ResponseWriter w, Request r) {
        var stats = fab.getStats()
        writeJson(w, stats)
    }

    // GET /api/processors — list active processor names
    pub fn processorsHandler(ResponseWriter w, Request r) {
        var names = fab.getProcessorNames()
        writeJson(w, names)
    }

    // GET /api/registry — list available processor types
    pub fn registryHandler(ResponseWriter w, Request r) {
        var reg = fab.getRegistry()
        var infos = reg.list()
        var result = List<Map<String, Object>>[]
        for info in infos {
            var entry = Map<String, Object>{}
            entry["name"] = info.name
            entry["description"] = info.description
            entry["configKeys"] = info.configKeys
            result = append(result, entry)
        }
        writeJson(w, result)
    }

    // GET /api/routes — list all routing rules
    pub fn routesHandler(ResponseWriter w, Request r) {
        var engine = fab.getEngine()
        var rules = engine.getAllRules()
        var result = List<Map<String, Object>>[]
        for rule in rules {
            var entry = Map<String, Object>{}
            entry["name"] = rule.name
            entry["enabled"] = rule.enabled
            entry["destination"] = rule.destination.endpoint
            entry["condition"] = formatCondition(rule.condition)
            result = append(result, entry)
        }
        writeJson(w, result)
    }

    // GET /api/flow — full flow graph (processors + routes)
    pub fn flowHandler(ResponseWriter w, Request r) {
        var flow = Map<String, Object>{}
        flow["processors"] = fab.getProcessorNames()

        var engine = fab.getEngine()
        var rules = engine.getAllRules()
        var routes = List<Map<String, Object>>[]
        for rule in rules {
            var entry = Map<String, Object>{}
            entry["name"] = rule.name
            entry["enabled"] = rule.enabled
            entry["destination"] = rule.destination.endpoint
            entry["condition"] = formatCondition(rule.condition)
            routes = append(routes, entry)
        }
        flow["routes"] = routes
        flow["stats"] = fab.getStats()
        writeJson(w, flow)
    }

    // GET /api/dlq — DLQ entries
    pub fn dlqHandler(ResponseWriter w, Request r) {
        var dlq = fab.getDLQ()
        var entries = dlq.list()
        var result = List<Map<String, Object>>[]
        for entry in entries {
            var e = Map<String, Object>{}
            e["id"] = entry.id
            e["sourceProcessor"] = entry.sourceProcessor
            e["sourceQueue"] = entry.sourceQueue
            e["attemptCount"] = entry.attemptCount
            e["lastError"] = entry.lastError
            e["arrivedAt"] = entry.arrivedAt
            e["flowFileId"] = entry.flowFile.id
            result = append(result, e)
        }
        writeJson(w, Map<String, Object>{"count": dlq.count(), "entries": result})
    }

    // POST /api/dlq/replay — replay a DLQ entry
    // Body: {"id": "dlq-1"}
    pub fn dlqReplayHandler(ResponseWriter w, Request r) {
        if r.Method != "POST" {
            writeError(w, 405, "method not allowed")
            return
        }
        var body = readBody(r)
        if body == null {
            writeError(w, 400, "failed to read body")
            return
        }
        var req = Map<String, Object>{}
        json.Unmarshal(body, req) or {
            writeError(w, 400, "invalid json")
            return
        }
        var id = strVal(req, "id")
        if id == "" {
            writeError(w, 400, "id is required")
            return
        }
        var dlq = fab.getDLQ()
        var entry = dlq.get(id)
        if entry.id == "" {
            writeError(w, 404, "dlq entry not found")
            return
        }
        var sourceQueue = entry.sourceQueue
        var ff = dlq.replay(id)
        fab.replayToQueue(sourceQueue, ff)
        writeJson(w, Map<String, Object>{"status": "replayed", "id": id, "flowFileId": ff.id, "queue": sourceQueue})
    }

    // POST /api/dlq/replay-all — replay all DLQ entries to their source queues
    pub fn dlqReplayAllHandler(ResponseWriter w, Request r) {
        if r.Method != "POST" {
            writeError(w, 405, "method not allowed")
            return
        }
        var dlq = fab.getDLQ()
        var entries = dlq.replayAll()
        var count = 0
        for entry in entries {
            fab.replayToQueue(entry.sourceQueue, entry.flowFile)
            count = count + 1
        }
        writeJson(w, Map<String, Object>{"status": "replayed", "count": count})
    }

    // DELETE /api/dlq — remove a DLQ entry
    // Body: {"id": "dlq-1"}
    pub fn dlqDeleteHandler(ResponseWriter w, Request r) {
        if r.Method != "DELETE" {
            writeError(w, 405, "method not allowed")
            return
        }
        var body = readBody(r)
        if body == null {
            writeError(w, 400, "failed to read body")
            return
        }
        var req = Map<String, Object>{}
        json.Unmarshal(body, req) or {
            writeError(w, 400, "invalid json")
            return
        }
        var id = strVal(req, "id")
        if id == "" {
            writeError(w, 400, "id is required")
            return
        }
        var dlq = fab.getDLQ()
        dlq.remove(id)
        writeJson(w, Map<String, Object>{"status": "removed", "id": id})
    }

    // GET /api/queues — queue depths for all processors
    pub fn queuesHandler(ResponseWriter w, Request r) {
        writeJson(w, fab.getQueueStats())
    }

    // POST /api/processors/enable — enable a processor
    // Body: {"name": "my-proc"}
    pub fn enableProcessorHandler(ResponseWriter w, Request r) {
        if r.Method != "POST" {
            writeError(w, 405, "method not allowed")
            return
        }
        var body = readBody(r)
        if body == null {
            writeError(w, 400, "failed to read body")
            return
        }
        var req = Map<String, Object>{}
        json.Unmarshal(body, req) or {
            writeError(w, 400, "invalid json")
            return
        }
        var name = strVal(req, "name")
        if name == "" {
            writeError(w, 400, "name is required")
            return
        }
        var ok = fab.enableProcessor(name)
        if !ok {
            writeError(w, 404, "processor not found")
            return
        }
        writeJson(w, Map<String, Object>{"status": "enabled", "name": name})
    }

    // POST /api/processors/disable — disable a processor (drains first)
    // Body: {"name": "my-proc", "timeout": 60}
    pub fn disableProcessorHandler(ResponseWriter w, Request r) {
        if r.Method != "POST" {
            writeError(w, 405, "method not allowed")
            return
        }
        var body = readBody(r)
        if body == null {
            writeError(w, 400, "failed to read body")
            return
        }
        var req = Map<String, Object>{}
        json.Unmarshal(body, req) or {
            writeError(w, 400, "invalid json")
            return
        }
        var name = strVal(req, "name")
        if name == "" {
            writeError(w, 400, "name is required")
            return
        }
        var drainSecs = 60
        var ok = fab.disableProcessor(name, drainSecs)
        if !ok {
            writeError(w, 404, "processor not found")
            return
        }
        writeJson(w, Map<String, Object>{"status": "draining", "name": name, "drainTimeout": drainSecs})
    }

    // POST /api/processors/state — get processor lifecycle state
    // Body: {"name": "my-proc"}
    pub fn processorStateHandler(ResponseWriter w, Request r) {
        var body = readBody(r)
        if body == null {
            writeError(w, 400, "failed to read body")
            return
        }
        var req = Map<String, Object>{}
        json.Unmarshal(body, req) or {
            writeError(w, 400, "invalid json")
            return
        }
        var name = strVal(req, "name")
        if name == "" {
            writeError(w, 400, "name is required")
            return
        }
        var state = fab.getProcessorState(name)
        var stateStr = "DISABLED"
        match state {
            case ENABLED { stateStr = "ENABLED" }
            case DRAINING { stateStr = "DRAINING" }
            case DISABLED { stateStr = "DISABLED" }
        }
        writeJson(w, Map<String, Object>{"name": name, "state": stateStr})
    }

    // POST /api/processors — add a processor
    // Body: {"name": "my-proc", "type": "add-attribute", "config": {"key": "env", "value": "prod"}}
    pub fn addProcessorHandler(ResponseWriter w, Request r) {
        if r.Method != "POST" {
            writeError(w, 405, "method not allowed")
            return
        }
        var body = readBody(r)
        if body == null {
            writeError(w, 400, "failed to read body")
            return
        }
        var req = Map<String, Object>{}
        json.Unmarshal(body, req) or {
            writeError(w, 400, "invalid json")
            return
        }
        var name = strVal(req, "name")
        var typeName = strVal(req, "type")
        if name == "" || typeName == "" {
            writeError(w, 400, "name and type are required")
            return
        }
        var config = Map<String, String>{}
        if req.containsKey("config") {
            var rawConfig = Map<String, String>{}
            var configBytes = json.Marshal(req["config"]) or { byte[0] }
            json.Unmarshal(configBytes, rawConfig) or {}
            var keys = rawConfig.keys()
            for k in keys {
                config[k] = rawConfig[k]
            }
        }
        var ok = fab.addProcessor(name, typeName, config)
        if !ok {
            writeError(w, 409, "processor already exists or unknown type")
            return
        }
        w.WriteHeader(201)
        writeJson(w, Map<String, Object>{"status": "created", "name": name})
    }

    // DELETE /api/processors — remove a processor
    // Body: {"name": "my-proc"}
    pub fn removeProcessorHandler(ResponseWriter w, Request r) {
        if r.Method != "DELETE" {
            writeError(w, 405, "method not allowed")
            return
        }
        var body = readBody(r)
        if body == null {
            writeError(w, 400, "failed to read body")
            return
        }
        var req = Map<String, Object>{}
        json.Unmarshal(body, req) or {
            writeError(w, 400, "invalid json")
            return
        }
        var name = strVal(req, "name")
        if name == "" {
            writeError(w, 400, "name is required")
            return
        }
        var ok = fab.removeProcessor(name)
        if !ok {
            writeError(w, 404, "processor not found")
            return
        }
        writeJson(w, Map<String, Object>{"status": "removed", "name": name})
    }

    // POST /api/routes — add a routing rule
    // Body: {"name": "my-route", "attribute": "type", "operator": "EQ", "value": "order", "destination": "proc-1"}
    pub fn addRouteHandler(ResponseWriter w, Request r) {
        if r.Method != "POST" {
            writeError(w, 405, "method not allowed")
            return
        }
        var body = readBody(r)
        if body == null {
            writeError(w, 400, "failed to read body")
            return
        }
        var req = Map<String, Object>{}
        json.Unmarshal(body, req) or {
            writeError(w, 400, "invalid json")
            return
        }
        var name = strVal(req, "name")
        var attr = strVal(req, "attribute")
        var op = strVal(req, "operator")
        var val = strVal(req, "value")
        var dest = strVal(req, "destination")
        if name == "" || attr == "" || op == "" || dest == "" {
            writeError(w, 400, "name, attribute, operator, and destination are required")
            return
        }
        fab.addRoute(name, attr, op, val, dest)
        w.WriteHeader(201)
        writeJson(w, Map<String, Object>{"status": "created", "name": name})
    }

    // DELETE /api/routes — remove a routing rule
    // Body: {"name": "my-route"}
    pub fn removeRouteHandler(ResponseWriter w, Request r) {
        if r.Method != "DELETE" {
            writeError(w, 405, "method not allowed")
