        writeJson(w, Map<String, Object>{"status": "toggled", "name": name})
    }

    // GET /api/providers — list all providers and their states
    pub fn providersHandler(ResponseWriter w, Request r) {
        var ctx = fab.getContext()
        var names = ctx.listProviders()
        var result = List<Map<String, Object>>[]
        for name in names {
            var entry = Map<String, Object>{}
            entry["name"] = name
            var prov = ctx.getProvider(name) or {
                entry["state"] = "UNKNOWN"
                result = append(result, entry)
                continue
            }
            entry["type"] = prov.getType()
            var state = prov.getState()
            match state {
                case ENABLED { entry["state"] = "ENABLED" }
                case DRAINING { entry["state"] = "DRAINING" }
                case DISABLED { entry["state"] = "DISABLED" }
            }
            result = append(result, entry)
        }
        writeJson(w, result)
    }

    // POST /api/providers/enable — enable a provider
    // Body: {"name": "content"}
    pub fn enableProviderHandler(ResponseWriter w, Request r) {
        if r.Method != "POST" {
            writeError(w, 405, "method not allowed")
