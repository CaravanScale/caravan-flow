        }
        var body = readBody(r)
        if body == null {
            writeError(w, 400, "failed to read body")
            return
        }
        var req = Map<String, Object>{}
        json.Unmarshal(body, req) or {
            writeError(w, 400, "invalid json")
            return
        }
        var name = strVal(req, "name")
        if name == "" {
            writeError(w, 400, "name is required")
            return
        }
        var ok = fab.removeRoute(name)
        if !ok {
            writeError(w, 404, "route not found")
            return
