    // POST /api/providers/disable — disable a provider (cascades to dependent processors)
    // Body: {"name": "content"}
    pub fn disableProviderHandler(ResponseWriter w, Request r) {
        if r.Method != "POST" {
            writeError(w, 405, "method not allowed")
            return
        }
        var body = readBody(r)
        if body == null {
            writeError(w, 400, "failed to read body")
            return
        }
        var req = Map<String, Object>{}
        json.Unmarshal(body, req) or {
            writeError(w, 400, "invalid json")
            return
        }
        var name = strVal(req, "name")
        if name == "" {
            writeError(w, 400, "name is required")
            return
        }
        var drainSecs = 60
        var ok = fab.disableProvider(name, drainSecs)
        if !ok {
            writeError(w, 404, "provider not found")
            return
        }
        writeJson(w, Map<String, Object>{"status": "disabled", "name": name})
    }
}

// readBody reads the full request body, returning null on failure.
fn readBody(Request r): byte[] {
    var body = ReadAll(r.Body) or {
        return null
    }
    r.Body.Close()
    return body
}

// strVal extracts a string value from a map, returning "" if missing.
fn strVal(Map<String, Object> m, String key): String {
    if m.containsKey(key) {
        return str(m[key])
    }
    return ""
}

// writeError writes a JSON error response.
fn writeError(ResponseWriter w, int status, String msg) {
    w.Header().Set("Content-Type", "application/json")
    w.WriteHeader(status)
    var result = Map<String, Object>{"error": msg}
    var body = json.Marshal(result) or { '{"error":"unknown"}'.toBytes() }
    w.Write(body)
}

// writeJson serializes data to JSON and writes it as the HTTP response.
fn writeJson(ResponseWriter w, Object data) {
    var body = json.Marshal(data) or {
        w.WriteHeader(500)
        w.Write('{"error":"json marshal failed"}'.toBytes())
        return
    }
    w.Header().Set("Content-Type", "application/json")
    w.Write(body)
}

// formatCondition converts a RuleType to a human-readable string.
fn formatCondition(RuleType condition): String {
    match condition {
        case BaseRule(attr, op, val) {
            return "${attr} ${formatOp(op)} ${val}"
        }
        case CompositeRule(left, joiner, right) {
            var joinStr = "AND"
            match joiner {
                case OR { joinStr = "OR" }
            }
            return "(${formatCondition(left)} ${joinStr} ${formatCondition(right)})"
        }
    }
    return "unknown"
}

fn formatOp(Operator op): String {
    match op {
        case EQ { return "==" }
        case NEQ { return "!=" }
        case CONTAINS { return "contains" }
        case STARTSWITH { return "startsWith" }
        case ENDSWITH { return "endsWith" }
        case EXISTS { return "exists" }
        case GT { return ">" }
        case LT { return "<" }
    }
    return "?"
}
