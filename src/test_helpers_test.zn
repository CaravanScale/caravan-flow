// Test-only helpers. Lives in *_test.zn so it's excluded from the prod
// binary (go build skips *_test.go files) but available to sibling
// *_test.zn files.

import core

// testContext builds a ProcessorContext backed by MemoryContentStore.
// Used by any test that needs to exercise the content provider path.
pub ProcessorContext testContext() {
    var store = MemoryContentStore()
    var cp = ContentProvider("content", store)
    cp.enable()
    var ctx = ProcessorContext()
    ctx.addProvider(cp)
    return ctx
}

// testScopedContext builds a ScopedContext with a single content provider.
// Mirrors what the fabric gives a processor at scope-construction time.
pub ScopedContext testScopedContext() {
    var store = MemoryContentStore()
    var cp = ContentProvider("content", store)
    cp.enable()
    var providers = Map<String, Provider>{}
    providers["content"] = cp
    return ScopedContext(providers)
}

// Canned JSON test data. Single-quoted strings are literal (no interpolation).

pub byte[] testJsonArray() {
    return '[{"name": "Alice", "amount": 42}]'.toBytes()
}

pub byte[] testJsonGeo() {
    return '[{"city": "Portland"}]'.toBytes()
}
