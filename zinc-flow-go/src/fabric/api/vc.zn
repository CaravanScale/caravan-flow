// VersionControl REST endpoints. Mounted at /api/vc/status,
// /api/vc/commit, /api/vc/push on the management port. Mirrors csharp
// ApiHandler VcStatus / VcCommit / VcPush (Fabric/ApiHandler.cs:81-83).

import net/http
import encoding/json
import core
import io

class VcApiHandler {
    VersionControlProvider vc

    init(VersionControlProvider vc) {
        this.vc = vc
    }

    // GET /api/vc/status — branch, clean, ahead/behind, repo, remote.
    pub void statusHandler(ResponseWriter w, Request r) {
        var s = vc.getStatus()
        var out = Map<String, Object>{}
        out["enabled"] = s.enabled
        out["clean"] = s.clean
        out["ahead"] = s.ahead
        out["behind"] = s.behind
        out["branch"] = s.branch
        out["remote"] = vc.remote
        out["repo"] = vc.repo
        if (s.errorMsg != "") {
            out["error"] = s.errorMsg
        }
        writeJson(w, out)
    }

    // POST /api/vc/commit — body {"path": "...", "message": "..."}.
    // Empty path stages everything (`.`). Returns the CommandResult shape.
    pub void commitHandler(ResponseWriter w, Request r) {
        var req = parseCommitRequest(r) or {
            w.WriteHeader(400)
            w.Write('{"error":"failed to parse body"}'.toBytes())
            return
        }
        var res = vc.commit(req["path"], req["message"])
        writeCommandResult(w, res)
    }

    // POST /api/vc/push — push the configured branch to the configured remote.
    pub void pushHandler(ResponseWriter w, Request r) {
        var res = vc.push()
        writeCommandResult(w, res)
    }
}

(Map<String, String>, error) parseCommitRequest(Request r) {
    var raw = byte[0]
    using (var rc = r.Body) {
        raw = io.ReadAll(rc) or { return Map<String, String>{}, err }
    }
    var parsed = Map<String, String>{}
    json.Unmarshal(raw, &parsed) or { return Map<String, String>{}, err }
    return parsed, null
}

void writeCommandResult(ResponseWriter w, CommandResult res) {
    var out = Map<String, Object>{}
    out["ok"] = res.ok
    out["exitCode"] = res.exitCode
    out["stdout"] = res.stdout
    out["stderr"] = res.stderr
    if (!res.ok) {
        w.WriteHeader(500)
    }
    writeJson(w, out)
}
