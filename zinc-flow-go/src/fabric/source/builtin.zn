// Builtin source registrations. Mirrors csharp BuiltinSources.RegisterAll
// (Fabric/Sources.cs:35). Each factory returns null when its required
// config keys are absent so an operator can leave a `sources:` entry
// stubbed without breaking startup.

import core
import fabric/registry
import strconv

pub void registerBuiltinSources(SourceRegistry reg) {
    reg.register(
        SourceInfo("GenerateFlowFile",
            "Timer-driven FlowFile generator for heartbeats and load tests.",
            List<String>["content", "contentType", "attributes", "batchSize", "pollIntervalMs"]),
        GenerateFlowFileFactory)

    reg.register(
        SourceInfo("GetFile",
            "Polls a directory; emits one FlowFile per file landing in it.",
            List<String>["inputDir", "pattern", "moveSubdir"]),
        GetFileFactory)

    reg.register(
        SourceInfo("ListenHTTP",
            "Binds an HTTP listener on {port}{path}; each POST body becomes a FlowFile.",
            List<String>["port", "path", "maxBodyBytes"]),
        ListenHTTPFactory)
}

(ConnectorSource, error) GenerateFlowFileFactory(String name, Map<String, String> config, ContentStore store) {
    var content = ""
    if (config.containsKey("content")) { content = config["content"] }
    if (content == "") {
        // Required-key omission: factory returns null source + null
        // error so the loader skips this instance (parity with csharp).
        return null, null
    }
    var contentType = ""
    if (config.containsKey("contentType")) { contentType = config["contentType"] }
    var attrs = ""
    if (config.containsKey("attributes")) { attrs = config["attributes"] }
    var batchSize = 1
    if (config.containsKey("batchSize") && config["batchSize"] != "") {
        batchSize = strconv.Atoi(config["batchSize"]) catch { 1 }
    }
    var pollMs = 1000
    if (config.containsKey("pollIntervalMs") && config["pollIntervalMs"] != "") {
        pollMs = strconv.Atoi(config["pollIntervalMs"]) catch { 1000 }
    }
    return GenerateFlowFile(name, pollMs, content, contentType, attrs, batchSize), null
}

(ConnectorSource, error) ListenHTTPFactory(String name, Map<String, String> config, ContentStore store) {
    var port = 0
    if (config.containsKey("port") && config["port"] != "") {
        port = strconv.Atoi(config["port"]) catch { 0 }
    }
    if (port <= 0) {
        // No port = disabled. Operators must opt in; we never default to
        // a port that could collide with the management server.
        return null, null
    }
    var path = "/"
    if (config.containsKey("path") && config["path"] != "") {
        path = config["path"]
    }
    var maxBytes = 16 * 1024 * 1024
    if (config.containsKey("maxBodyBytes") && config["maxBodyBytes"] != "") {
        maxBytes = strconv.Atoi(config["maxBodyBytes"]) catch { 16 * 1024 * 1024 }
    }
    return ListenHTTP(name, port, path, maxBytes), null
}

(ConnectorSource, error) GetFileFactory(String name, Map<String, String> config, ContentStore store) {
    var dir = ""
    if (config.containsKey("inputDir")) { dir = config["inputDir"] }
    if (dir == "") {
        return null, null
    }
    var pattern = "*"
    if (config.containsKey("pattern") && config["pattern"] != "") {
        pattern = config["pattern"]
    }
    var moveSubdir = ".processed"
    if (config.containsKey("moveSubdir") && config["moveSubdir"] != "") {
        moveSubdir = config["moveSubdir"]
    }
    return GetFile(name, dir, moveSubdir, pattern), null
}
