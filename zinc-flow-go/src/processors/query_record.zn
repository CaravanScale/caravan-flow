// QueryRecord — filter records using a JSONPath query (RFC-9535).
//
// Backed by github.com/ohler55/ojg/jp — well-maintained Go JSONPath
// implementation with a precompile step (jp.ParseString → expr) so
// the path is parsed once at factory time and re-applied per FlowFile.
//
// Examples:
//   $[?(@.amount > 100)]                  rows where amount exceeds 100
//   $[?(@.priority == 'high')]            rows with a specific string value
//   $[?(@.address.country == 'US')]       nested predicate
//   $[?(@.qty >= 2 && @.qty <= 10)]       compound filter
//   $[*]                                  match everything
//
// Implementation: each record is mirrored into a Go map (with the
// original index tagged as "_idx") so jp.Get returns matched maps from
// which we recover the original record indices. Schema and original
// types are preserved — no re-materialization from JSON.
//
// Mirrors zinc-flow-csharp/ZincFlow/StdLib/RecordProcessors.cs#QueryRecord.

import stdlib/errors
import strings
import core
import ojgJp
import fabric/registry

class QueryRecord : ProcessorFn {
    String query
    bool matchAll
    ojgJp.Expr expr

    init(String query, bool matchAll, ojgJp.Expr expr) {
        this.query = query
        this.matchAll = matchAll
        this.expr = expr
    }

    pub ProcessorResult process(FlowFile ff) {
        match (ff.content) {
            case Records(schema, records) {
                if (len(records) == 0) {
                    return Single(ff)
                }
                if (matchAll) {
                    return Single(ff)
                }
                // Build a tagged []any view: each record becomes
                // map[string]any with an "_idx" sentinel preserving
                // the original record's position so we can rebuild
                // the kept-records list from jp.Get's matches.
                var view = List<Object>[]
                var i = 0
                while (i < len(records)) {
                    var m = recordToMap(records[i])
                    m["_idx"] = i
                    view = append(view, m)
                    i = i + 1
                }
                var matches = expr.Get(view)
                var keepIdx = Map<int, bool>{}
                for (hit in matches) {
                    extractIdx(hit, keepIdx)
                }
                if (len(keepIdx) == 0) {
                    return Dropped("QueryRecord: no records matched")
                }
                var kept = List<GenericRecord>[]
                var j = 0
                while (j < len(records)) {
                    if (keepIdx.containsKey(j)) {
                        kept = append(kept, records[j])
                    }
                    j = j + 1
                }
                var updated = withContent(ff, Records(schema, kept))
                return Single(updated)
            }
            case _ {
                return Single(ff)
            }
        }
    }
}

// recordToMap mirrors a GenericRecord into Map<String, Object> so the
// JSONPath evaluator (which expects a Go-native any-tree) can walk
// fields by name. Field-by-field copy preserves typed values; OCF
// roundtrip semantics aren't disturbed because the original record
// list is what gets returned (matches just tell us which to keep).
Map<String, Object> recordToMap(GenericRecord rec) {
    var m = Map<String, Object>{}
    for (f in rec.getSchema().fields) {
        var v = rec.getField(f.name)
        if (v != null) {
            m[f.name] = v
        }
    }
    return m
}

// extractIdx pulls the "_idx" sentinel out of a JSONPath match. A
// match at the record level is map[string]any (the record-as-map);
// deeper-path matches (e.g. `$[*].name`) come back as scalars and
// we ignore them — the per-record predicate shape is what
// QueryRecord supports today.
void extractIdx(Object hit, Map<int, bool> keepIdx) {
    var asMap = hit as Map<String, Object> or { return }
    if (!asMap.containsKey("_idx")) { return }
    var idx = asMap["_idx"] as int or { return }
    keepIdx[idx] = true
}

pub (ProcessorFn, error) QueryRecordFactory(ScopedContext ctx, Map<String, String> config) {
    var query = "$"
    if (config.containsKey("query")) {
        query = strings.TrimSpace(config["query"])
    }
    if (query == "") { query = "$" }
    if (query == "$" || query == "$[*]") {
        return QueryRecord(query, true, default(ojgJp.Expr)), null
    }
    var expr = ojgJp.ParseString(query) or {
        return QueryRecord(query, false, default(ojgJp.Expr)),
            errors.ConfigError("QueryRecord: bad JSONPath '${query}': ${err.Error()}")
    }
    return QueryRecord(query, false, expr), null
}
