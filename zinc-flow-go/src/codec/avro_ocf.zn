// Avro Object Container File (OCF) reader/writer + ConvertOCFToRecord /
// ConvertRecordToOCF processors.
//
// Backed by github.com/hamba/avro/v2/ocf — Encoder/Decoder handle the
// file format, codec selection (null/deflate/snappy/zstandard), block
// framing, and sync markers. The zinc side wires bytes.Buffer ↔ FlowFile
// content and bridges zinc Schema ↔ Avro JSON ↔ hamba Schema.
//
// File layout (spec §1.11.1 §object_container_files) is hamba's
// responsibility. We only deal with byte slices on each end.

import core
import bytes
import fabric/registry
import hambaAvro
import hambaOcf
import stdlib/errors
import stdlib/logging
import strconv
import strings
import sync

// --- Constants ----------------------------------------------------------

pub const CODEC_NULL = "null"
pub const CODEC_DEFLATE = "deflate"
pub const CODEC_ZSTANDARD = "zstandard"
pub const CODEC_SNAPPY = "snappy"

bool isSupportedCodec(String c) {
    return c == CODEC_NULL || c == CODEC_DEFLATE ||
           c == CODEC_ZSTANDARD || c == CODEC_SNAPPY
}

// --- OCF reader ---------------------------------------------------------

// readOcf parses an OCF blob using hamba's streaming decoder. Returns the
// writer schema (decoded from header metadata via the JSON we asked for),
// every record found in the file, and any error from hamba.
pub (core.Schema, List<GenericRecord>, error) readOcf(byte[] data) {
    var zero = core.Schema("", List<core.Field>[])
    if (len(data) == 0) {
        return zero, List<GenericRecord>[], errors.ConfigError("OCF empty input")
    }
    var rdr = bytes.NewReader(data)
    var dec = hambaOcf.NewDecoder(rdr) catch {
        return zero, List<GenericRecord>[], err
    }

    // hamba doesn't expose the parsed writer schema directly, but
    // round-trip files written via writeOcf carry the JSON in the
    // standard `avro.schema` metadata key. Pull it back out, parse on
    // the zinc side, and use that as the canonical schema.
    var meta = dec.Metadata()
    if (!meta.containsKey("avro.schema")) {
        return zero, List<GenericRecord>[], errors.ConfigError("OCF metadata missing avro.schema")
    }
    var schema = parseSchemaJson(string(meta["avro.schema"])) catch {
        return zero, List<GenericRecord>[], errors.ConfigError("OCF schema invalid: ${err.Error()}")
    }

    var records = List<GenericRecord>[]
    while (dec.HasNext()) {
        var raw = Map<String, Object>{}
        dec.Decode(&raw) catch {
            return zero, records, err
        }
        var rec = GenericRecord(schema)
        for (k, v in raw) {
            rec.setField(k, v)
        }
        records = append(records, rec)
    }
    if (dec.Error() != null) {
        return zero, records, dec.Error()
    }
    return schema, records, null
}

// --- OCF writer ---------------------------------------------------------

// writeOcf serializes records into an OCF blob using hamba's streaming
// encoder. Writes a single block per Encode call (default block-length
// behavior — hamba flushes on Close).
pub (byte[], error) writeOcf(List<GenericRecord> records, core.Schema schema, String codec) {
    if (!isSupportedCodec(codec)) {
        return byte[0], errors.ConfigError("unsupported OCF codec: ${codec}")
    }
    var schemaJson = emitSchemaJson(schema) catch {
        return byte[0], errors.ConfigError("OCF schema JSON emit failed: ${err.Error()}")
    }

    var buf = new bytes.Buffer
    using (var enc = hambaOcf.NewEncoder(schemaJson, buf, hambaOcf.WithCodec(hambaOcf.CodecName(codec))) catch { return byte[0], err }) {
        for (rec in records) {
            enc.Encode(coerceForSchema(rec, schema)) catch {
                return byte[0], err
            }
        }
    }
    return buf.Bytes(), null
}

// --- Processors ---------------------------------------------------------

// ConvertOCFToRecord — decodes an OCF blob to records, optionally projecting
// onto a reader schema for evolution. Reader schema can be supplied three
// ways (mutually exclusive): inline JSON via `readerSchema`; registry-backed
// via `readerSchemaSubject` (+ optional `readerSchemaVersion`, default
// "latest"); or absent (records keep the writer schema verbatim).
//
// `autoRegisterSubject`: after each successful decode, register the writer
// schema embedded in the OCF under this subject. Identical-schema dedup
// means re-reading a known file is a no-op; a never-before-seen schema
// becomes a new version. Auto-register failures are logged at WARN but
// never block the FlowFile (advisory side effect).
//
// Registry paths require the `schema_registry` provider; the factory
// rejects the config if it's missing.
class ConvertOCFToRecord : ProcessorFn {
    ContentStore store
    String readerSchemaJson
    SchemaRegistry? schemaRegistry
    String readerSchemaSubject
    String readerSchemaVersion
    String autoRegisterSubject
    core.Schema? resolvedReaderSchema  // cached registry result; bypassed when version=="latest"
    sync.Mutex resolveMu

    init(ContentStore store, String readerSchemaJson) {
        this.store = store
        this.readerSchemaJson = readerSchemaJson
        this.schemaRegistry = null
        this.readerSchemaSubject = ""
        this.readerSchemaVersion = "latest"
        this.autoRegisterSubject = ""
        this.resolvedReaderSchema = null
    }

    // Setter for registry-backed reader schema. Called from the factory when
    // `readerSchemaSubject` is in config; tests can call directly.
    pub void useRegistryReader(SchemaRegistry sr, String subject, String version) {
        this.schemaRegistry = sr
        this.readerSchemaSubject = subject
        if (version != "") {
            this.readerSchemaVersion = version
        }
    }

    // Setter for auto-register-on-decode of the writer schema. Independent of
    // `useRegistryReader` — a processor may auto-register without projecting.
    pub void useAutoRegister(SchemaRegistry sr, String subject) {
        this.schemaRegistry = sr
        this.autoRegisterSubject = subject
    }

    pub ProcessorResult process(FlowFile ff) {
        var data = byte[0]
        match (ff.content) {
            case Raw(bytes) {
                data = bytes
            }
            case Claim(_, _) {
                var resolved = resolve(store, ff.content)
                if (resolved.errorMsg != "") {
                    return Failure(resolved.errorMsg, ff)
                }
                data = resolved.data
            }
            case Records(_, _) {
                return Single(ff)
            }
        }

        // Resolve the reader schema lazily. Inline JSON wins; otherwise hit
        // the registry (cached unless version == "latest"). A registry miss
        // becomes a Failure on this FlowFile, never a runtime panic.
        core.Schema? readerSchema = null
        if (readerSchemaJson != "") {
            var s = parseSchemaJson(readerSchemaJson) catch {
                return Failure("ConvertOCFToRecord: reader schema invalid: ${err.Error()}", ff)
            }
            readerSchema = s
        } else if (readerSchemaSubject != "" && schemaRegistry != null) {
            var s = resolveReaderFromRegistry() catch {
                return Failure("ConvertOCFToRecord: registry lookup failed for ${readerSchemaSubject}@${readerSchemaVersion}: ${err.Error()}", ff)
            }
            readerSchema = s
        }

        var writerSchema, records = readOcf(data) catch {
            return Failure("ConvertOCFToRecord: ${err.Error()}", ff)
        }
        if (len(records) == 0) {
            return Failure("ConvertOCFToRecord: no records in OCF", ff)
        }

        // Auto-register the writer schema if configured. Advisory: a registry
        // failure logs WARN and is dropped; the FlowFile continues.
        if (autoRegisterSubject != "" && schemaRegistry != null) {
            var sr = schemaRegistry as SchemaRegistry
            sr.register(autoRegisterSubject, writerSchema) catch {
                logging.warn("ConvertOCFToRecord: auto-register failed",
                    "subject", autoRegisterSubject, "err", err.Error())
            }
        }

        // Project records onto the reader schema if one is in play.
        // schema_resolver.check enforces compatibility per Avro 1.11
        // resolution rules; .project handles per-field promotion + defaults.
        var effectiveSchema = writerSchema
        if (readerSchema != null) {
            var rs = readerSchema as core.Schema
            var compat = check(rs, writerSchema)
            if (!compat.isCompatible()) {
                return Failure("ConvertOCFToRecord: reader schema incompatible: " + strings.Join(compat.errors, "; "), ff)
            }
            var projected = List<GenericRecord>[]
            for (rec in records) {
                projected = append(projected, project(rec, rs, writerSchema))
            }
            records = projected
            effectiveSchema = rs
        }

        var updated = withContent(ff, Records(effectiveSchema, records))
        return Single(updated)
    }

    // resolveReaderFromRegistry returns the cached schema when version is
    // pinned and we've already fetched once; otherwise hits the registry and
    // caches the result (skipping the cache for "latest" so newly promoted
    // versions get picked up).
    (core.Schema, error) resolveReaderFromRegistry() {
        if (schemaRegistry == null) {
            return core.Schema("", List<core.Field>[]), errors.ConfigError("schema_registry not configured")
        }
        var sr = schemaRegistry as SchemaRegistry

        if (readerSchemaVersion != "latest") {
            lock (resolveMu) {
                if (resolvedReaderSchema != null) {
                    return resolvedReaderSchema as core.Schema, null
                }
            }
        }

        VersionEntry? entry = null
        if (readerSchemaVersion == "latest") {
            entry = sr.getLatest(readerSchemaSubject)
        } else {
            var v = strconv.Atoi(readerSchemaVersion) catch {
                return core.Schema("", List<core.Field>[]), errors.ConfigError("invalid version '${readerSchemaVersion}': not an integer")
            }
            entry = sr.getEntry(readerSchemaSubject, v)
        }
        if (entry == null) {
            return core.Schema("", List<core.Field>[]), errors.ConfigError("subject '${readerSchemaSubject}' version '${readerSchemaVersion}' not found")
        }
        var schema = (entry as VersionEntry).schema

        if (readerSchemaVersion != "latest") {
            lock (resolveMu) {
                resolvedReaderSchema = schema
            }
        }
        return schema, null
    }
}

pub (ProcessorFn, error) ConvertOCFToRecordFactory(ScopedContext ctx, Map<String, String> config) {
    var inlineReader = ""
    if (config.containsKey("readerSchema")) {
        inlineReader = config["readerSchema"]
    }
    var subject = ""
    if (config.containsKey("readerSchemaSubject")) {
        subject = config["readerSchemaSubject"]
    }
    var version = ""
    if (config.containsKey("readerSchemaVersion")) {
        version = config["readerSchemaVersion"]
    }
    var autoRegister = ""
    if (config.containsKey("autoRegisterSubject")) {
        autoRegister = config["autoRegisterSubject"]
    }

    if (inlineReader != "" && subject != "") {
        return null, errors.ConfigError("ConvertOCFToRecord: set readerSchema OR readerSchemaSubject, not both")
    }

    // Registry lookup: only when the user actually asked for it.
    SchemaRegistry? sr = null
    if (subject != "" || autoRegister != "") {
        var p = ctx.getProvider("schema_registry") catch {
            return null, errors.ConfigError("ConvertOCFToRecord: readerSchemaSubject/autoRegisterSubject require the 'schema_registry' provider")
        }
        var srp = p as SchemaRegistryProvider
        sr = srp.getRegistry()
    }

    // Content store path mirrors ConvertAvroToRecordFactory: fall back to
    // MemoryContentStore when no provider is registered (test fixtures, etc.).
    var p = ctx.getProvider("content") catch {
        return buildOCFReader(MemoryContentStore(), inlineReader, sr, subject, version, autoRegister), null
    }
    var cp = p as ContentProvider
    return buildOCFReader(cp.getStore(), inlineReader, sr, subject, version, autoRegister), null
}

ConvertOCFToRecord buildOCFReader(ContentStore store, String inlineReader,
        SchemaRegistry? sr, String subject, String version, String autoRegister) {
    var proc = ConvertOCFToRecord(store, inlineReader)
    if (subject != "" && sr != null) {
        proc.useRegistryReader(sr as SchemaRegistry, subject, version)
    }
    if (autoRegister != "" && sr != null) {
        proc.useAutoRegister(sr as SchemaRegistry, autoRegister)
    }
    return proc
}

class ConvertRecordToOCF : ProcessorFn {
    String codec

    init(String codec) {
        this.codec = codec
    }

    pub ProcessorResult process(FlowFile ff) {
        match (ff.content) {
            case Records(schema, records) {
                if (len(records) == 0) {
                    return Single(ff)
                }
                if (len(schema.fields) == 0) {
                    return Failure("ConvertRecordToOCF: Records content has empty schema", ff)
                }
                var bytes = writeOcf(records, schema, codec) catch {
                    return Failure("ConvertRecordToOCF: ${err.Error()}", ff)
                }
                var updated = withContent(ff, Raw(bytes))
                return Single(updated)
            }
            case Raw(_) {
                return Single(ff)
            }
            case Claim(_, _) {
                return Single(ff)
            }
        }
    }
}

pub (ProcessorFn, error) ConvertRecordToOCFFactory(ScopedContext ctx, Map<String, String> config) {
    var codec = CODEC_NULL
    if (config.containsKey("codec") && config["codec"] != "") {
        codec = config["codec"]
    }
    if (!isSupportedCodec(codec)) {
        return null, errors.ConfigError("ConvertRecordToOCF: unsupported codec '${codec}' — valid: null, deflate, snappy, zstandard")
    }
    return ConvertRecordToOCF(codec), null
}

// Reader-schema projection lives in schema_resolver.zn (check + project) —
// the per-record path applied above handles promotion + defaults per the
// Avro 1.11 resolution rules. Earlier ad-hoc projectRecords removed.
