// Avro binary codec — ConvertAvroToRecord / ConvertRecordToAvro processors,
// plus parseFieldDefs / emitFieldDefs.
//
// Backed by github.com/hamba/avro/v2 — Marshal/Unmarshal handle the wire
// format. The zinc-side responsibilities are: schema bridging
// (zinc Schema → Avro JSON → hamba Schema), shape adaptation
// (GenericRecord.values is already map[string]any, which hamba accepts
// directly for record types), and the FlowFile content/attribute plumbing.
//
// Scope:
//   • Single-record raw binary Avro per FlowFile. Multi-record streams
//     (with framing) live in OCF.
//   • Primitive field types only (NULL/BOOLEAN/INT/LONG/FLOAT/DOUBLE/
//     STRING/BYTES) — same as csharp's AvroBinary. hamba supports more,
//     but emitSchemaJson + the local Schema enum gate at primitives.
//   • Schema sourcing for ConvertAvroToRecord: config `fieldDefs`
//     ("id:long,name:string") wins; falls back to the FlowFile's
//     `avro.schema` attribute.
//   • ConvertRecordToAvro stamps `avro.schema` on output so the inverse
//     processor can round-trip without out-of-band schema config.
//
// Failure paths:
//   • Missing schema → Failure
//   • hamba.Parse / Marshal / Unmarshal error → Failure
//   • Zero-field schema after parseFieldDefs → Failure
//   • ConvertRecordToAvro on Records content with empty schema → Failure

import core
import fabric/registry
import hambaAvro
import stdlib/errors
import stdlib/logging
import strings

// --- ConvertAvroToRecord processor -------------------------------------

class ConvertAvroToRecord : ProcessorFn {
    String schemaName
    String fieldDefs
    ContentStore store

    init(String schemaName, String fieldDefs, ContentStore store) {
        this.schemaName = schemaName
        this.fieldDefs = fieldDefs
        this.store = store
    }

    pub ProcessorResult process(FlowFile ff) {
        var data = byte[0]
        match (ff.content) {
            case Raw(bytes) {
                data = bytes
            }
            case Claim(_, _) {
                var resolved = resolve(store, ff.content)
                if (resolved.errorMsg != "") {
                    return Failure(resolved.errorMsg, ff)
                }
                data = resolved.data
            }
            case Records(_, _) {
                return Single(ff)
            }
        }

        // Schema priority: config fieldDefs > avro.schema attribute.
        var defs = fieldDefs
        if (defs == "" && ff.attributes.containsKey("avro.schema")) {
            defs = ff.attributes["avro.schema"]
        }
        if (defs == "") {
            return Failure("ConvertAvroToRecord: no schema — set 'fieldDefs' config or 'avro.schema' attribute", ff)
        }
        var schema = parseFieldDefs(schemaName, defs) catch {
            return Failure("ConvertAvroToRecord: ${err.Error()}", ff)
        }
        if (len(schema.fields) == 0) {
            return Failure("ConvertAvroToRecord: empty schema", ff)
        }

        var schemaJson = emitSchemaJson(schema) catch {
            return Failure("ConvertAvroToRecord: schema emit failed: ${err.Error()}", ff)
        }
        var hSchema = hambaAvro.Parse(schemaJson) catch {
            return Failure("ConvertAvroToRecord: hamba.Parse: ${err.Error()}", ff)
        }

        var target = Map<String, Object>{}
        hambaAvro.Unmarshal(hSchema, data, &target) catch {
            return Failure("ConvertAvroToRecord: decode failed: ${err.Error()}", ff)
        }

        var rec = GenericRecord(schema)
        for (k, v in target) {
            rec.setField(k, v)
        }

        var records = List<GenericRecord>[]
        records = append(records, rec)
        var updated = withContent(ff, Records(schema, records))
        return Single(updated)
    }
}

pub (ProcessorFn, error) ConvertAvroToRecordFactory(ScopedContext ctx, Map<String, String> config) {
    var schemaName = "avro"
    if (config.containsKey("schemaName") && config["schemaName"] != "") {
        schemaName = config["schemaName"]
    }
    var fieldDefs = ""
    if (config.containsKey("fieldDefs")) {
        fieldDefs = config["fieldDefs"]
    }
    var p = ctx.getProvider("content") catch {
        return ConvertAvroToRecord(schemaName, fieldDefs, MemoryContentStore()), null
    }
    var cp = p as ContentProvider
    return ConvertAvroToRecord(schemaName, fieldDefs, cp.getStore()), null
}

// --- ConvertRecordToAvro processor -------------------------------------

class ConvertRecordToAvro : ProcessorFn {

    init() {}

    pub ProcessorResult process(FlowFile ff) {
        match (ff.content) {
            case Records(schema, records) {
                if (len(records) == 0) {
                    return Single(ff)
                }
                if (len(schema.fields) == 0) {
                    return Failure("ConvertRecordToAvro: Records content has empty schema", ff)
                }

                var schemaJson = emitSchemaJson(schema) catch {
                    return Failure("ConvertRecordToAvro: schema emit failed: ${err.Error()}", ff)
                }
                var hSchema = hambaAvro.Parse(schemaJson) catch {
                    return Failure("ConvertRecordToAvro: hamba.Parse: ${err.Error()}", ff)
                }

                // Single-record only — the inverse processor reads one record
                // per blob. Multi-record streams live in avro_ocf.zn.
                var rec = records[0]
                var bytes = hambaAvro.Marshal(hSchema, coerceForSchema(rec, schema)) catch {
                    return Failure("ConvertRecordToAvro: encode failed: ${err.Error()}", ff)
                }

                var stamped = withAttribute(ff, "avro.schema", emitFieldDefs(schema))
                var updated = withContent(stamped, Raw(bytes))
                if (len(records) > 1) {
                    logging.warn("ConvertRecordToAvro: dropping records beyond first",
                        "kept", 1, "dropped", len(records) - 1)
                }
                return Single(updated)
            }
            case Raw(_) {
                return Single(ff)
            }
            case Claim(_, _) {
                return Single(ff)
            }
        }
    }
}

pub (ProcessorFn, error) ConvertRecordToAvroFactory(ScopedContext ctx, Map<String, String> config) {
    return ConvertRecordToAvro(), null
}

// coerceForSchema returns a map[string]any whose value Go-types match what
// hamba expects for each schema field. The path that matters: JSON
// upstream produces float64 for every number, which hamba rejects when
// the schema says int/long. CSV upstream produces strings; user code is
// usually correct (long/int explicitly). We coerce a small set of common
// cases here; anything else passes through untouched and lets hamba error
// surface to Failure.
Map<String, Object> coerceForSchema(GenericRecord rec, core.Schema schema) {
    var out = Map<String, Object>{}
    for (f in schema.fields) {
        var v = rec.getField(f.name)
        match (f.fieldType) {
            case INT     { out[f.name] = asInt(v) }
            case LONG    { out[f.name] = asLong(v) }
            case FLOAT   { out[f.name] = asFloat32(v) }
            case DOUBLE  { out[f.name] = asDouble(v) }
            case BOOLEAN { out[f.name] = asBool(v) }
            case STRING  { out[f.name] = asString(v) }
            case BYTES   { out[f.name] = asBytes(v) }
            case _       { out[f.name] = v }
        }
    }
    return out
}

// --- Type coercion helpers ---------------------------------------------
// Records can arrive from JSON (json.Unmarshal yields float64 for every
// number), CSV (every cell is a string), or user code. hamba is strict
// about the value type matching the schema's primitive — these helpers
// normalize so encode succeeds without per-call-site casting.

bool asBool(Object v) {
    if (v == null) { return false }
    var b = v as bool catch {
        var s = v as String catch { return false }
        return s == "true"
    }
    return b
}

int asInt(Object v) {
    if (v == null) { return 0 }
    var i = v as int catch {
        var l = v as long catch {
            var f = v as double catch { return 0 }
            return int(f)
        }
        return int(l)
    }
    return i
}

long asLong(Object v) {
    if (v == null) { return long(0) }
    var l = v as long catch {
        var i = v as int catch {
            var f = v as double catch { return long(0) }
            return long(f)
        }
        return long(i)
    }
    return l
}

double asDouble(Object v) {
    if (v == null) { return 0.0 }
    var f = v as double catch {
        var i = v as int catch {
            var l = v as long catch { return 0.0 }
            return double(l)
        }
        return double(i)
    }
    return f
}

// asFloat32 — hamba expects Go float32 for "float" Avro type. Zinc has no
// float32 surface, so we return double here and rely on hamba's tolerance
// for double values when the schema says float (it does the narrowing).
double asFloat32(Object v) {
    return asDouble(v)
}

String asString(Object v) {
    if (v == null) { return "" }
    var s = v as String catch { return "" }
    return s
}

byte[] asBytes(Object v) {
    if (v == null) { return byte[0] }
    var s = v as String catch { return byte[0] }
    return s.toBytes()
}

// --- fieldDefs parser/emitter -----------------------------------------

// parseFieldDefs — "id:long, name:string" → Schema. Same syntax as csharp
// (RecordProcessors.cs:54). Names case-sensitive; types fold to lowercase.
pub (core.Schema, error) parseFieldDefs(String name, String defs) {
    var fields = List<core.Field>[]
    var trimmed = strings.TrimSpace(defs)
    if (trimmed == "") {
        return core.Schema(name, fields), null
    }
    for (part in strings.Split(trimmed, ",")) {
        var p = strings.TrimSpace(part)
        if (p == "") {
            continue
        }
        var idx = strings.Index(p, ":")
        if (idx < 0) {
            return core.Schema("", List<core.Field>[]), errors.ConfigError("malformed field def '${p}' — expected 'name:type'")
        }
        var fname = strings.TrimSpace(p[0:idx])
        var ftypeStr = strings.ToLower(strings.TrimSpace(p[idx+1:len(p)]))
        if (fname == "" || ftypeStr == "") {
            return core.Schema("", List<core.Field>[]), errors.ConfigError("malformed field def '${p}' — expected 'name:type'")
        }
        var ft = fieldTypeFromName(ftypeStr) catch {
            return core.Schema("", List<core.Field>[]), errors.ConfigError("field '${fname}': ${err.Error()}")
        }
        fields = append(fields, core.Field(fname, ft, null))
    }
    return core.Schema(name, fields), null
}

pub String emitFieldDefs(core.Schema s) {
    var parts = List<String>[]
    for (f in s.fields) {
        parts = append(parts, f.name + ":" + fieldTypeName(f.fieldType))
    }
    return strings.Join(parts, ",")
}

(FieldType, error) fieldTypeFromName(String name) {
    if (name == "null")                        { return NULL,    null }
    if (name == "boolean" || name == "bool")   { return BOOLEAN, null }
    if (name == "int" || name == "int32")      { return INT,     null }
    if (name == "long" || name == "int64")     { return LONG,    null }
    if (name == "float" || name == "float32")  { return FLOAT,   null }
    if (name == "double" || name == "float64") { return DOUBLE,  null }
    if (name == "string")                      { return STRING,  null }
    if (name == "bytes")                       { return BYTES,   null }
    return NULL, errors.ConfigError("unknown field type '${name}' — valid: null, boolean, int, long, float, double, string, bytes")
}

String fieldTypeName(FieldType ft) {
    match (ft) {
        case NULL    { return "null" }
        case BOOLEAN { return "boolean" }
        case INT     { return "int" }
        case LONG    { return "long" }
        case FLOAT   { return "float" }
        case DOUBLE  { return "double" }
        case STRING  { return "string" }
        case BYTES   { return "bytes" }
        case ARRAY   { return "array" }
        case MAP     { return "map" }
        case RECORD  { return "record" }
        case ENUM    { return "enum" }
        case UNION   { return "union" }
    }
}
