// Smoke tests for hamba/avro through zinc's explicit `&` FFI operator.
// Two distinct seams are exercised:
//
//   1. Package-level call: `hambaAvro.Unmarshal(schema, data, &got)`.
//      `Unmarshal` takes `v any` but requires a runtime pointer; `&got`
//      is the explicit escape hatch.
//
//   2. Method call on a Go-typed receiver: `dec.Decode(&got)` where
//      `dec` is the `*ocf.Decoder` returned by `hambaOcf.NewDecoder(r)`.
//      Same any-boxing problem, different call shape — and the gate that
//      lets `&` through has to recognize the Go-typed var, not just the
//      package alias. (Regression net for the formatCallExpr fix that
//      checks `varGoTypes` outside the user-scope-shadow guard.)
//
// If both tests compile AND the generated Go has `&got` at each call
// site, the FFI path works.

import bytes
import hambaAvro
import hambaOcf
import stdlib/asserts

data Person(@Avro("name") String name, @Avro("age") int age)

test "hamba round-trip: Marshal/Unmarshal with explicit & on Unmarshal" {
    var schemaStr = `{"type":"record","name":"Person","fields":[{"name":"name","type":"string"},{"name":"age","type":"int"}]}`
    var schema = hambaAvro.Parse(schemaStr) or {
        asserts.fail(t, "schema parse failed: ${err}")
        return
    }

    var p = Person("alice", 30)
    var data = hambaAvro.Marshal(schema, p) or {
        asserts.fail(t, "marshal failed: ${err}")
        return
    }
    asserts.isTrue(t, len(data) > 0, "non-empty avro bytes")

    // The interesting bit: `&got` is the explicit FFI escape hatch.
    // Without it, hamba would receive a value-typed Person and panic
    // at runtime (the pre-`&` behavior the implicitPointerParams hack
    // papered over).
    var got = Person("", 0)
    hambaAvro.Unmarshal(schema, data, &got) or {
        asserts.fail(t, "unmarshal failed: ${err}")
        return
    }
    asserts.equalString(t, got.name, "alice")
    asserts.equalInt(t, got.age, 30)
}

test "hamba/ocf round-trip: dec.Decode(&got) — method-call FFI seam" {
    var schemaStr = `{"type":"record","name":"Person","fields":[{"name":"name","type":"string"},{"name":"age","type":"int"}]}`

    // Encode one Person into an OCF blob via the streaming Encoder.
    var buf = new bytes.Buffer
    var enc, eerr = hambaOcf.NewEncoder(schemaStr, buf)
    asserts.isTrue(t, eerr == nil, "ocf encoder construct")
    var p = Person("bob", 41)
    enc.Encode(p) or {
        asserts.fail(t, "encode failed: ${err}")
        return
    }
    enc.Close() or {
        asserts.fail(t, "encoder close failed: ${err}")
        return
    }

    // Decode it back. `dec` is *ocf.Decoder (Go-typed local var); the
    // `&got` argument exercises the FFI-on-method-call gate.
    var rdr = bytes.NewReader(buf.Bytes())
    var dec, derr = hambaOcf.NewDecoder(rdr)
    asserts.isTrue(t, derr == nil, "ocf decoder construct")
    asserts.isTrue(t, dec.HasNext(), "decoder has next record")

    var got = Person("", 0)
    dec.Decode(&got) or {
        asserts.fail(t, "ocf decode failed: ${err}")
        return
    }
    asserts.equalString(t, got.name, "bob")
    asserts.equalInt(t, got.age, 41)
}
