// GetFile source tests. Kept in their own file so the imports needed
// for filesystem + concurrency testing (os, time, strings, sync) don't
// pollute symbol resolution in the broader processors_test.zn — the
// existing FileSink / WriteFile codegen path is sensitive to test-file
// imports and adding os/sync there caused false-widening of unrelated
// process() call sites.

import core
import fabric/source
import stdlib/asserts
import os
import time
import strings
import sync

test "GetFile — pollOnce picks up existing files and moves them" {
    var dir = "/tmp/zinc-flow-test/getfile-poll-${time.Now().UnixNano()}"
    os.MkdirAll(dir, 0o755)
    os.WriteFile(dir + "/a.txt", "alpha".toBytes(), 0o644)
    os.WriteFile(dir + "/b.txt", "beta".toBytes(), 0o644)

    var src = GetFile("test", dir, ".processed", "*")
    var emitted = src.pollOnce()
    asserts.equalInt(t, len(emitted), 2)

    // Each FF carries filename + size + source attrs.
    for (ff in emitted) {
        var fname = ff.attributes["filename"]
        asserts.isTrue(t, fname == "a.txt" || fname == "b.txt", "filename is one of seeded files")
        asserts.equalString(t, ff.attributes["source"], "test")
    }

    // Files moved to .processed/, originals gone.
    var afterEntries = os.ReadDir(dir) or {
        t.Errorf("could not read dir after poll")
        return
    }
    var topLevelFiles = 0
    for (e in afterEntries) {
        if (!e.IsDir() && !strings.HasPrefix(e.Name(), ".")) {
            topLevelFiles = topLevelFiles + 1
        }
    }
    asserts.equalInt(t, topLevelFiles, 0)

    var processedEntries = os.ReadDir(dir + "/.processed") or {
        t.Errorf("no .processed dir")
        return
    }
    asserts.equalInt(t, len(processedEntries), 2)
}

test "GetFile — pattern filter skips non-matching files" {
    var dir = "/tmp/zinc-flow-test/getfile-pat-${time.Now().UnixNano()}"
    os.MkdirAll(dir, 0o755)
    os.WriteFile(dir + "/keep.json", "{}".toBytes(), 0o644)
    os.WriteFile(dir + "/skip.txt", "skipped".toBytes(), 0o644)

    var src = GetFile("test", dir, ".processed", "*.json")
    var emitted = src.pollOnce()
    asserts.equalInt(t, len(emitted), 1)
    asserts.equalString(t, emitted[0].attributes["filename"], "keep.json")
}

