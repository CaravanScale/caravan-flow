// Round-trip tests for Avro 1.11 binary primitives.
// Validates the hand-rolled encoding against the spec — byte-exact for
// known fixtures (Apache Avro spec §primitive types §binary encoding).

import codec
import stdlib/asserts

test "zigzag — round-trip signed longs" {
    var inputs = List<long>[long(0), long(-1), long(1), long(-2), long(2),
        long(2147483647), long(-2147483648), long(9223372036854775807)]
    for (n in inputs) {
        var encoded = codec.zigzagEncodeLong(n)
        var decoded = codec.zigzagDecodeLong(encoded)
        asserts.isTrue(t, decoded == n, "zigzag round-trip ${n}")
    }
}

test "varint — known fixtures from the Avro spec" {
    // Apache Avro 1.11 §primitive types: int/long encoded as zigzag varint.
    // These pairs are from the spec's worked examples.
    //   value 0   →  0x00
    //   value -1  →  0x01
    //   value 1   →  0x02
    //   value -2  →  0x03
    //   value 2   →  0x04
    //   value 64  →  0x80 0x01
    //   value -65 →  0x81 0x01
    var values = List<long>[long(0), long(-1), long(1), long(-2), long(2), long(64), long(-65)]
    var expected = List<List<int>>[
        List<int>[0x00],
        List<int>[0x01],
        List<int>[0x02],
        List<int>[0x03],
        List<int>[0x04],
        List<int>[0x80, 0x01],
        List<int>[0x81, 0x01]
    ]
    var i = 0
    while (i < len(values)) {
        var got = codec.writeVarint(byte[0], values[i])
        asserts.equalInt(t, len(got), len(expected[i]))
        var j = 0
        while (j < len(expected[i])) {
            asserts.equalInt(t, int(got[j]), expected[i][j])
            j = j + 1
        }
        var decoded, n, err = codec.readVarint(got, 0)
        asserts.isTrue(t, err == nil, "readVarint no err")
        asserts.equalInt(t, n, len(got))
        asserts.isTrue(t, decoded == values[i], "readVarint round-trip")
        i = i + 1
    }
}

test "primitives — round-trip" {
    // bool
    var b1 = codec.writeBoolean(byte[0], true)
    var b2 = codec.writeBoolean(byte[0], false)
    asserts.equalInt(t, int(b1[0]), 1)
    asserts.equalInt(t, int(b2[0]), 0)

    // int
    var i1 = codec.writeInt(byte[0], 12345)
    var ri, _, _ = codec.readInt(i1, 0)
    asserts.equalInt(t, ri, 12345)

    // long
    var l1 = codec.writeLong(byte[0], long(-9999999999))
    var rl, _, _ = codec.readLong(l1, 0)
    asserts.isTrue(t, rl == long(-9999999999), "long round-trip")

    // float
    var f1 = codec.writeFloat(byte[0], 3.14159)
    asserts.equalInt(t, len(f1), 4)
    var rf, _, _ = codec.readFloat(f1, 0)
    asserts.isTrue(t, rf > 3.14 && rf < 3.15, "float round-trip ~ pi")

    // double
    var d1 = codec.writeDouble(byte[0], 2.718281828)
    asserts.equalInt(t, len(d1), 8)
    var rd, _, _ = codec.readDouble(d1, 0)
    asserts.isTrue(t, rd > 2.71 && rd < 2.72, "double round-trip ~ e")

    // string
    var s1 = codec.writeString(byte[0], "hello zinc")
    var rs, _, _ = codec.readString(s1, 0)
    asserts.equalString(t, rs, "hello zinc")

    // bytes
    var orig = byte[3]
    orig[0] = byte(0xDE); orig[1] = byte(0xAD); orig[2] = byte(0xBE)
    var bs = codec.writeBytes(byte[0], orig)
    var rb, _, _ = codec.readBytes(bs, 0)
    asserts.equalInt(t, len(rb), 3)
    asserts.equalInt(t, int(rb[0]), 0xDE)
    asserts.equalInt(t, int(rb[1]), 0xAD)
    asserts.equalInt(t, int(rb[2]), 0xBE)
}

test "varint — error on truncated input" {
    var truncated = byte[1]
    truncated[0] = byte(0x80)  // continuation bit set, but no more bytes
    var v, n, err = codec.readVarint(truncated, 0)
    asserts.isTrue(t, err != nil, "expected err on truncated varint")
    asserts.equalInt(t, n, 1)  // consumed the one byte before failing
    asserts.isTrue(t, v == 0, "value zero on err")
}
