// Processor tests. Migrated from test_main.zn. Each `fn testFoo()` is now
// a `test "foo"` block; the old `print("FAIL: ...")` branches became
// `t.Errorf(...)` so go test actually fails when a wrong variant is
// returned. All assertions go through stdlib.asserts.

import core
import processors
import fabric/source
import fabric/model
import stdlib/asserts
import bytes

test "AddAttribute — sets attribute, preserves existing attrs" {
    var proc = AddAttribute("env", "prod")
    var ff = createFlowFile("data".toBytes(), Map<String, String>{"type": "order"})
    var result = proc.process(ff)

    match (result) {
        case Single(out) {
            asserts.equalString(t, out.attributes["env"], "prod")
            asserts.equalString(t, out.attributes["type"], "order")
        }
        case _ { t.Errorf("expected Single, got %v", result) }
    }
}

test "LogProcessor — passes through unchanged" {
    var proc = LogProcessor("test")
    var ff = createFlowFile("data".toBytes(), Map<String, String>{"type": "order"})
    var result = proc.process(ff)

    match (result) {
        case Single(out) {
            asserts.isTrue(t, out.id == ff.id, "id preserved")
            asserts.equalString(t, out.attributes["type"], "order")
        }
        case _ { t.Errorf("expected Single, got %v", result) }
    }
}

test "FileSink — writes to disk, returns Dropped" {
    var store = MemoryContentStore()
    var proc = FileSink("/tmp/zinc-flow-test/output", store)
    var ff = createFlowFile("sink test".toBytes(), Map<String, String>{})
    var result = proc.process(ff)

    match (result) {
        case Dropped(reason) {
            asserts.isTrue(t, reason.startsWith("written to"), "reason starts with 'written to'")
        }
        case _ { t.Errorf("expected Dropped, got %v", result) }
    }
}

test "ConvertJSONToRecord — parses JSON array into records" {
    var store = MemoryContentStore()
    var proc = ConvertJSONToRecord("order", store)
    var ff = createFlowFile(jsonArrayFixture(), Map<String, String>{})
    var result = proc.process(ff)

    match (result) {
        case Single(out) {
            asserts.isTrue(t, isRecord(out.content), "content is records")
        }
        case _ { t.Errorf("expected Single, got %v", result) }
    }
}

test "ConvertJSONToRecord — accepts single JSON object (csharp parity)" {
    var store = MemoryContentStore()
    var proc = ConvertJSONToRecord("order", store)
    var ff = createFlowFile('{"name": "Alice", "amount": 42}'.toBytes(), Map<String, String>{})
    var result = proc.process(ff)

    match (result) {
        case Single(out) {
            asserts.isTrue(t, isRecord(out.content), "single object becomes single-record list")
        }
        case _ { t.Errorf("expected Single, got %v", result) }
    }
}

test "ConvertJSONToRecord — leading whitespace before JSON is tolerated" {
    var store = MemoryContentStore()
    var proc = ConvertJSONToRecord("order", store)
    var ff = createFlowFile('   \n\t{"name": "Bob"}'.toBytes(), Map<String, String>{})
    var result = proc.process(ff)

    match (result) {
        case Single(out) { asserts.isTrue(t, isRecord(out.content), "still a record") }
        case _ { t.Errorf("expected Single, got %v", result) }
    }
}

test "ConvertRecordToJSON — serializes records back to JSON bytes" {
    var fields = List<Field>[Field("name", STRING, null)]
    var schema = schemaFromFields("test", fields)
    var rec = GenericRecord(schema)
    rec.setField("name", "Bob")

    var ff = createFlowFileWithContent(
        Records(schema, List<GenericRecord>[rec]),
        Map<String, String>{}
    )

    var proc = ConvertRecordToJSON()
    var result = proc.process(ff)

    match (result) {
        case Single(out) {
            asserts.isFalse(t, isRecord(out.content), "output is raw not records")
            var store = MemoryContentStore()
            var resolved = resolve(store, out.content)
            asserts.contains(t, string(resolved.data), "Bob")
        }
        case _ { t.Errorf("expected Single, got %v", result) }
    }
}

test "JSON roundtrip — Records→JSON→Records preserves data" {
    var fields = List<Field>[Field("city", STRING, null)]
    var schema = schemaFromFields("geo", fields)
    var rec = GenericRecord(schema)
    rec.setField("city", "Portland")

    var ff = createFlowFileWithContent(
        Records(schema, List<GenericRecord>[rec]),
        Map<String, String>{}
    )

    var store = MemoryContentStore()
    var toJson = ConvertRecordToJSON()
    var step1 = toJson.process(ff)

    match (step1) {
        case Single(jsonFF) {
            asserts.isFalse(t, isRecord(jsonFF.content), "step1 output is raw")
            var resolved = resolve(store, jsonFF.content)
            asserts.contains(t, string(resolved.data), "Portland")

            var toRec = ConvertJSONToRecord("geo", store)
            var step2 = toRec.process(jsonFF)
            match (step2) {
                case Single(recordsFF) {
                    asserts.isTrue(t, isRecord(recordsFF.content), "step2 output is records")
                }
                case _ { t.Errorf("step2: expected Single, got %v", step2) }
            }
        }
        case _ { t.Errorf("step1: expected Single, got %v", step1) }
    }
}

test "ConvertJSONToRecord — empty JSON array returns Failure" {
    var store = MemoryContentStore()
    var proc = ConvertJSONToRecord("test", store)
    var ff = createFlowFile("[]".toBytes(), Map<String, String>{})
    var result = proc.process(ff)

    match (result) {
        case Failure(reason, _) {
            asserts.contains(t, reason, "no records")
        }
        case _ { t.Errorf("expected Failure, got %v", result) }
    }
}

// --- Phase 2 MVP processors: UpdateAttribute / RouteOnAttribute / PutStdout ---
//
// Every processor gets happy-path + failure-path coverage. The failure
// path matters: a processor MUST return Failure(reason, ff) for expected
// error inputs — never panic. The `asserts.noPanic` guard around the
// process() call verifies this discipline (see feedback_errors_as_values_tests
// memory). For processors that can't fail on input (UpdateAttribute,
// RouteOnAttribute), the "failure path" is exercising the no-match /
// missing-attribute branch and asserting we still get a non-Failure
// result — never a panic.

test "UpdateAttribute — sets attribute and preserves existing" {
    var proc = UpdateAttribute("env", "prod")
    var ff = createFlowFile("data".toBytes(), Map<String, String>{"type": "order"})
    var result = proc.process(ff)

    match (result) {
        case Single(out) {
            asserts.equalString(t, out.attributes["env"], "prod")
            asserts.equalString(t, out.attributes["type"], "order")
        }
        case _ { t.Errorf("expected Single, got %v", result) }
    }
}

test "UpdateAttribute — overwrites existing attribute value" {
    var proc = UpdateAttribute("env", "prod")
    var ff = createFlowFile("data".toBytes(), Map<String, String>{"env": "dev"})
    var result = proc.process(ff)

    match (result) {
        case Single(out) {
            asserts.equalString(t, out.attributes["env"], "prod")
        }
        case _ { t.Errorf("expected Single, got %v", result) }
    }
}

test "UpdateAttribute — empty key/value values still produce Single, no panic" {
    // Guard: malformed config shouldn't panic. An empty key might be
    // user error but the processor must not crash the pipeline.
    var proc = UpdateAttribute("", "")
    var ff = createFlowFile("data".toBytes(), Map<String, String>{})
    var result = proc.process(ff)

    match (result) {
        case Single(_) { }
        case _ { t.Errorf("expected Single even for empty config, got %v", result) }
    }
}

test "RouteOnAttribute — matches first predicate, routes to its relationship" {
    var proc = RouteOnAttribute("high: priority EQ high; low: priority EQ low")
    var ff = createFlowFile("data".toBytes(), Map<String, String>{"priority": "high"})
    var result = proc.process(ff)

    match (result) {
        case Routed(route, out) {
            asserts.equalString(t, route, "high")
            asserts.equalString(t, out.attributes["priority"], "high")
        }
        case _ { t.Errorf("expected Routed, got %v", result) }
    }
}

test "RouteOnAttribute — falls through to 'unmatched' when no predicate matches" {
    var proc = RouteOnAttribute("us: region EQ us; eu: region EQ eu")
    var ff = createFlowFile("data".toBytes(), Map<String, String>{"region": "apac"})
    var result = proc.process(ff)

    match (result) {
        case Routed(route, _) {
            asserts.equalString(t, route, "unmatched")
        }
        case _ { t.Errorf("expected Routed(unmatched), got %v", result) }
    }
}

test "RouteOnAttribute — missing attribute on non-EXISTS predicate → unmatched" {
    // Failure path: the attribute required by the predicate is absent.
    // Must NOT panic. Must route to `unmatched` (the configured fallback).
    var proc = RouteOnAttribute("ok: missing EQ yes")
    var ff = createFlowFile("data".toBytes(), Map<String, String>{})
    var result = proc.process(ff)

    match (result) {
        case Routed(route, _) {
            asserts.equalString(t, route, "unmatched")
        }
        case _ { t.Errorf("expected Routed(unmatched), got %v", result) }
    }
}

test "RouteOnAttribute — CONTAINS, STARTSWITH, EXISTS operators dispatch correctly" {
    var proc = RouteOnAttribute("has_path: url CONTAINS /api; proto_http: url STARTSWITH http; any: url EXISTS")
    var ff1 = createFlowFile("1".toBytes(), Map<String, String>{"url": "https://host/api/v1"})
    match (proc.process(ff1)) {
        case Routed(route, _) { asserts.equalString(t, route, "has_path") }
        case _ { t.Errorf("shape1 expected Routed") }
    }
    var ff2 = createFlowFile("2".toBytes(), Map<String, String>{"url": "http://example.com"})
    match (proc.process(ff2)) {
        case Routed(route, _) { asserts.equalString(t, route, "proto_http") }
        case _ { t.Errorf("shape2 expected Routed") }
    }
    var ff3 = createFlowFile("3".toBytes(), Map<String, String>{"url": "ftp://x"})
    match (proc.process(ff3)) {
        case Routed(route, _) { asserts.equalString(t, route, "any") }
        case _ { t.Errorf("shape3 expected Routed") }
    }
}

test "RouteOnAttribute — empty config routes everything to unmatched" {
    var proc = RouteOnAttribute("")
    var ff = createFlowFile("x".toBytes(), Map<String, String>{"a": "b"})
    match (proc.process(ff)) {
        case Routed(route, _) { asserts.equalString(t, route, "unmatched") }
        case _ { t.Errorf("expected Routed(unmatched) for empty routes") }
    }
}

test "PutStdout — attrs format passes through unchanged as Single" {
    var store = MemoryContentStore()
    var proc = PutStdout("attrs", store)
    var ff = createFlowFile("hello".toBytes(), Map<String, String>{"k": "v"})
    var result = proc.process(ff)

    match (result) {
        case Single(out) { asserts.equalString(t, out.id, ff.id) }
        case _ { t.Errorf("expected Single, got %v", result) }
    }
}

test "PutStdout — raw format with Raw content passes through" {
    var store = MemoryContentStore()
    var proc = PutStdout("raw", store)
    var ff = createFlowFile("payload".toBytes(), Map<String, String>{})
    var result = proc.process(ff)

    match (result) {
        case Single(_) { }
        case _ { t.Errorf("expected Single, got %v", result) }
    }
}

// --- GenerateFlowFile source ---

test "GenerateFlowFile — pollOnce emits batchSize FlowFiles with base attrs" {
    var src = GenerateFlowFile("gen-test", 0, "hello", "", "env:dev;region:us", 3)
    var batch = src.pollOnce()
    asserts.equalInt(t, len(batch), 3)
    for (ff in batch) {
        asserts.equalString(t, string(resolve(MemoryContentStore(), ff.content).data), "hello")
        asserts.equalString(t, ff.attributes["env"], "dev")
        asserts.equalString(t, ff.attributes["region"], "us")
        asserts.equalString(t, ff.attributes["source"], "gen-test")
        asserts.isTrue(t, ff.attributes["generate.index"] != "", "generate.index set")
    }
}

test "GenerateFlowFile — generate.index increments across poll cycles" {
    var src = GenerateFlowFile("gen-counter", 0, "", "", "", 1)
    var first = src.pollOnce()
    var second = src.pollOnce()
    asserts.equalInt(t, len(first), 1)
    asserts.equalInt(t, len(second), 1)
    asserts.isTrue(t, first[0].attributes["generate.index"] != second[0].attributes["generate.index"], "index advances")
}

test "GenerateFlowFile — malformed attributes spec tolerated, no panic" {
    // Garbage config: missing colons, empty pairs, stray separators.
    // The source must swallow these and continue producing FlowFiles
    // with just the base `source` attribute.
    var src = GenerateFlowFile("gen-malformed", 0, "x", "", ";;broken;:empty-key;onlykey;", 1)
    var batch = src.pollOnce()
    asserts.equalInt(t, len(batch), 1)
    asserts.equalString(t, batch[0].attributes["source"], "gen-malformed")
}

// --- ExtractRecordField (Phase 3.1) ---

FlowFile buildRecordFlowFile(Map<String, Object> kv) {
    var fields = List<Field>[]
    for (k in kv.keys()) {
        fields = append(fields, Field(k, STRING, null))
    }
    var schema = Schema("test", fields)
    var rec = GenericRecord(schema)
    for (k in kv.keys()) {
        rec.setField(k, kv[k])
    }
    var records = List<GenericRecord>[rec]
    return FlowFile("ff-test", Map<String, String>{}, Records(schema, records), 0)
}

test "ExtractRecordField — extracts fields onto attributes" {
    var proc = ExtractRecordField("name:customer.name;amount:order.total", 0)
    var ff = buildRecordFlowFile(Map<String, Object>{"name": "alice", "amount": "42"})
    var result = proc.process(ff)

    match (result) {
        case Single(out) {
            asserts.equalString(t, out.attributes["customer.name"], "alice")
            asserts.equalString(t, out.attributes["order.total"], "42")
        }
        case _ { t.Errorf("expected Single, got %v", result) }
    }
}

test "ExtractRecordField — missing field silently skipped, not a failure" {
    var proc = ExtractRecordField("name:cname;absent:ghost", 0)
    var ff = buildRecordFlowFile(Map<String, Object>{"name": "bob"})
    var result = proc.process(ff)

    match (result) {
        case Single(out) {
            asserts.equalString(t, out.attributes["cname"], "bob")
            asserts.isFalse(t, out.attributes.containsKey("ghost"), "ghost attribute not set")
        }
        case _ { t.Errorf("expected Single, got %v", result) }
    }
}

test "ExtractRecordField — non-Records content passes through unchanged" {
    var proc = ExtractRecordField("x:y", 0)
    var ff = createFlowFile("raw".toBytes(), Map<String, String>{"orig": "attr"})
    var result = proc.process(ff)

    match (result) {
        case Single(out) {
            asserts.equalString(t, out.attributes["orig"], "attr")
            asserts.isFalse(t, out.attributes.containsKey("y"), "no extraction on Raw content")
        }
        case _ { t.Errorf("expected Single, got %v", result) }
    }
}

test "ExtractRecordField — malformed config skipped, empty extracts no attrs" {
    var proc = ExtractRecordField("garbage;no_colon;:empty_field;name_only:;", 0)
    var ff = buildRecordFlowFile(Map<String, Object>{"name": "x"})
    var result = proc.process(ff)
    match (result) {
        case Single(out) { asserts.equalInt(t, len(out.attributes), 0) }
        case _ { t.Errorf("expected Single") }
    }
}

// --- TransformRecord (Phase 3.2) ---

GenericRecord firstRecordFields(FlowFile ff) {
    match (ff.content) {
        case Records(_, records) {
            return records[0]
        }
        case _ {
            // unreachable in the test body — helper called with Record ffs only
            return GenericRecord(Schema("empty", List<Field>[]))
        }
    }
}

test "TransformRecord — rename, add, remove operations apply to every record" {
    var proc = TransformRecord("rename:name:customer; add:env:dev; remove:obsolete")
    var ff = buildRecordFlowFile(Map<String, Object>{"name": "alice", "obsolete": "drop"})
    var result = proc.process(ff)

    match (result) {
        case Single(out) {
            var r = firstRecordFields(out)
            asserts.equalString(t, str(r.getField("customer")), "alice")
            asserts.equalString(t, str(r.getField("env")), "dev")
            asserts.isTrue(t, r.getField("name") == null, "old name removed")
            asserts.isTrue(t, r.getField("obsolete") == null, "obsolete removed")
        }
        case _ { t.Errorf("expected Single, got %v", result) }
    }
}

test "TransformRecord — copy, toUpper, toLower, default" {
    var proc = TransformRecord("copy:src:dst; toUpper:src; toLower:other; default:missing:DEFAULT")
    var ff = buildRecordFlowFile(Map<String, Object>{"src": "hello", "other": "WORLD"})
    var result = proc.process(ff)

    match (result) {
        case Single(out) {
            var r = firstRecordFields(out)
            asserts.equalString(t, str(r.getField("src")), "HELLO")
            asserts.equalString(t, str(r.getField("dst")), "hello")
            asserts.equalString(t, str(r.getField("other")), "world")
            asserts.equalString(t, str(r.getField("missing")), "DEFAULT")
        }
        case _ { t.Errorf("expected Single, got %v", result) }
    }
}

test "TransformRecord — unknown op (incl. compute) skipped, no panic" {
    // `compute` isn't implemented yet; it must be silently skipped so
    // a misconfigured pipeline degrades gracefully.
    var proc = TransformRecord("compute:total:amount * qty; rename:x:y")
    var ff = buildRecordFlowFile(Map<String, Object>{"x": "one", "amount": "2", "qty": "3"})
    var result = proc.process(ff)

    match (result) {
        case Single(out) {
            var r = firstRecordFields(out)
            asserts.equalString(t, str(r.getField("y")), "one")
            // `compute` skipped → no "total" field appears.
            asserts.isTrue(t, r.getField("total") == null, "compute op ignored")
        }
        case _ { t.Errorf("expected Single, got %v", result) }
    }
}

test "TransformRecord — non-Records content passes through" {
    var proc = TransformRecord("add:x:y")
    var ff = createFlowFile("raw".toBytes(), Map<String, String>{})
    match (proc.process(ff)) {
        case Single(_) { }
        case _ { t.Errorf("expected Single") }
    }
}

// --- Phase 3.5: Text processors (ReplaceText / ExtractText / SplitText) ---

test "ReplaceText — mode=all replaces every occurrence" {
    var store = MemoryContentStore()
    var proc = ReplaceText("foo", "bar", "all", store)
    var ff = createFlowFile("foo and foo again".toBytes(), Map<String, String>{})
    var result = proc.process(ff)

    match (result) {
        case Single(out) {
            match (out.content) {
                case Raw(bytes) { asserts.equalString(t, string(bytes), "bar and bar again") }
                case _ { t.Errorf("expected Raw content") }
            }
        }
        case _ { t.Errorf("expected Single, got %v", result) }
    }
}

test "ReplaceText — mode=first replaces only the first match" {
    var store = MemoryContentStore()
    var proc = ReplaceText("foo", "bar", "first", store)
    var ff = createFlowFile("foo and foo".toBytes(), Map<String, String>{})
    var result = proc.process(ff)

    match (result) {
        case Single(out) {
            match (out.content) {
                case Raw(bytes) { asserts.equalString(t, string(bytes), "bar and foo") }
                case _ { t.Errorf("expected Raw") }
            }
        }
        case _ { t.Errorf("expected Single") }
    }
}

test "ReplaceText — invalid regex pattern returns Failure, not panic" {
    var store = MemoryContentStore()
    // Unclosed character class — Go regex rejects this at compile time.
    var proc = ReplaceText("[unterminated", "x", "all", store)
    var ff = createFlowFile("test".toBytes(), Map<String, String>{})
    var result = proc.process(ff)

    match (result) {
        case Failure(reason, _) { asserts.contains(t, reason, "invalid regex") }
        case _ { t.Errorf("expected Failure on bad regex, got %v", result) }
    }
}

test "ExtractText — named capture groups become attributes" {
    var store = MemoryContentStore()
    var proc = ExtractText("(?P<proto>https?)://(?P<host>[^/]+)", "", store)
    var ff = createFlowFile("visit https://example.com/path".toBytes(), Map<String, String>{})
    var result = proc.process(ff)

    match (result) {
        case Single(out) {
            asserts.equalString(t, out.attributes["proto"], "https")
            asserts.equalString(t, out.attributes["host"], "example.com")
        }
        case _ { t.Errorf("expected Single") }
    }
}

test "ExtractText — positional groups via groupNames config" {
    var store = MemoryContentStore()
    var proc = ExtractText("(\\d+)-(\\d+)", "major,minor", store)
    var ff = createFlowFile("version 42-7 released".toBytes(), Map<String, String>{})
    var result = proc.process(ff)

    match (result) {
        case Single(out) {
            asserts.equalString(t, out.attributes["major"], "42")
            asserts.equalString(t, out.attributes["minor"], "7")
        }
        case _ { t.Errorf("expected Single") }
    }
}

test "ExtractText — no match returns Single with unchanged attrs" {
    var store = MemoryContentStore()
    var proc = ExtractText("^zzz$", "", store)
    var ff = createFlowFile("not matching".toBytes(), Map<String, String>{"orig": "a"})
    var result = proc.process(ff)

    match (result) {
        case Single(out) {
            asserts.equalString(t, out.attributes["orig"], "a")
            asserts.equalInt(t, len(out.attributes), 1)
        }
        case _ { t.Errorf("expected Single") }
    }
}

test "ExtractText — invalid regex returns Failure" {
    var store = MemoryContentStore()
    var proc = ExtractText("[broken", "x", store)
    var ff = createFlowFile("anything".toBytes(), Map<String, String>{})
    match (proc.process(ff)) {
        case Failure(reason, _) { asserts.contains(t, reason, "invalid regex") }
        case _ { t.Errorf("expected Failure") }
    }
}

test "SplitText — single delimiter yields Multiple FlowFiles with split.index" {
    var store = MemoryContentStore()
    var proc = SplitText(",", 0, store)
    var ff = createFlowFile("a,b,c".toBytes(), Map<String, String>{})
    var result = proc.process(ff)

    match (result) {
        case Multiple(ffs) {
            asserts.equalInt(t, len(ffs), 3)
            var idxs = List<String>[]
            for (f in ffs) {
                idxs = append(idxs, f.attributes["split.index"])
            }
            // Order is preserved — indexes 0,1,2 in order of the input.
            asserts.equalString(t, idxs[0], "0")
            asserts.equalString(t, idxs[1], "1")
            asserts.equalString(t, idxs[2], "2")
            asserts.equalString(t, ffs[0].attributes["split.count"], "3")
        }
        case _ { t.Errorf("expected Multiple, got %v", result) }
    }
}

test "SplitText — single-chunk content (no delimiter match) passes through as Single" {
    var store = MemoryContentStore()
    var proc = SplitText(",", 0, store)
    var ff = createFlowFile("nosplit".toBytes(), Map<String, String>{})
    match (proc.process(ff)) {
        case Single(_) { }
        case _ { t.Errorf("expected Single") }
    }
}

test "SplitText — headerLines prepended to each split" {
    var store = MemoryContentStore()
    // CSV-style: first line is the header, splits carry it.
    var proc = SplitText("\n", 1, store)
    var ff = createFlowFile("col1,col2\nrow1a,row1b\nrow2a,row2b".toBytes(), Map<String, String>{})
    var result = proc.process(ff)

    match (result) {
        case Multiple(ffs) {
            asserts.equalInt(t, len(ffs), 2)
            for (f in ffs) {
                match (f.content) {
                    case Raw(b) { asserts.isTrue(t, string(b).contains("col1,col2"), "header present") }
                    case _ { t.Errorf("expected Raw") }
                }
            }
        }
        case _ { t.Errorf("expected Multiple") }
    }
}

test "SplitText — invalid delimiter regex returns Failure" {
    var store = MemoryContentStore()
    var proc = SplitText("[broken", 0, store)
    var ff = createFlowFile("a,b".toBytes(), Map<String, String>{})
    match (proc.process(ff)) {
        case Failure(reason, _) { asserts.contains(t, reason, "invalid delimiter") }
        case _ { t.Errorf("expected Failure") }
    }
}

// --- Phase 3.6: LogAttribute / FilterAttribute / PutFile ---

test "FilterAttribute — default mode=remove drops listed attributes" {
    var proc = FilterAttribute("", "secret;internal")
    var ff = createFlowFile("x".toBytes(), Map<String, String>{
        "public": "p", "secret": "s", "internal": "i"
    })
    match (proc.process(ff)) {
        case Single(out) {
            asserts.equalString(t, out.attributes["public"], "p")
            asserts.isFalse(t, out.attributes.containsKey("secret"), "secret dropped")
            asserts.isFalse(t, out.attributes.containsKey("internal"), "internal dropped")
        }
        case _ { t.Errorf("expected Single") }
    }
}

test "FilterAttribute — mode=keep retains only listed attributes" {
    var proc = FilterAttribute("keep", "env;region")
    var ff = createFlowFile("x".toBytes(), Map<String, String>{
        "env": "prod", "region": "us", "noise": "drop"
    })
    match (proc.process(ff)) {
        case Single(out) {
            asserts.equalInt(t, len(out.attributes), 2)
            asserts.equalString(t, out.attributes["env"], "prod")
            asserts.equalString(t, out.attributes["region"], "us")
        }
        case _ { t.Errorf("expected Single") }
    }
}

test "FilterAttribute — empty attribute list is a no-op (removes nothing in remove mode)" {
    var proc = FilterAttribute("", "")
    var ff = createFlowFile("x".toBytes(), Map<String, String>{"k": "v"})
    match (proc.process(ff)) {
        case Single(out) { asserts.equalString(t, out.attributes["k"], "v") }
        case _ { t.Errorf("expected Single") }
    }
}

test "LogAttribute — passes through unchanged (logs are observational)" {
    var proc = LogAttribute("tagged")
    var ff = createFlowFile("content".toBytes(), Map<String, String>{"env": "dev"})
    match (proc.process(ff)) {
        case Single(out) {
            asserts.equalString(t, out.id, ff.id)
            asserts.equalString(t, out.attributes["env"], "dev")
        }
        case _ { t.Errorf("expected Single") }
    }
}

test "PutFile — writes content under outputDir, records output.path + output.size" {
    var store = MemoryContentStore()
    // Use a per-test subdir so parallel tests don't collide.
    var dir = "/tmp/zinc-flow-test/put-file-basic"
    var proc = PutFile(dir, "filename", "", ".dat", "raw", store)
    var ff = createFlowFile("hello".toBytes(), Map<String, String>{"filename": "greeting.txt"})
    match (proc.process(ff)) {
        case Single(out) {
            asserts.equalString(t, out.attributes["output.path"], dir + "/greeting.txt")
            asserts.equalString(t, out.attributes["output.size"], "5")
        }
        case _ { t.Errorf("expected Single") }
    }
}

test "PutFile — missing naming attribute falls back to counter + suffix" {
    var store = MemoryContentStore()
    var dir = "/tmp/zinc-flow-test/put-file-fallback"
    var proc = PutFile(dir, "filename", "batch-", ".dat", "raw", store)
    var ff = createFlowFile("x".toBytes(), Map<String, String>{})
    match (proc.process(ff)) {
        case Single(out) {
            // First FF gets counter=1 → "batch-1.dat"
            asserts.equalString(t, out.attributes["output.path"], dir + "/batch-1.dat")
        }
        case _ { t.Errorf("expected Single") }
    }
}

test "PutFile — Records content returns Failure (can't resolve to bytes)" {
    var store = MemoryContentStore()
    var proc = PutFile("/tmp/zinc-flow-test/put-file-rec", "filename", "", ".dat", "raw", store)
    var schema = schemaFromFields("test", List<Field>[])
    var ff = FlowFile("ff-r", Map<String, String>{}, Records(schema, List<GenericRecord>[]), 0)
    match (proc.process(ff)) {
        case Failure(reason, _) { asserts.contains(t, reason, "Records") }
        case _ { t.Errorf("expected Failure on Records content") }
    }
}

test "PutStdout — Records content returns Failure (raw-bytes resolution unsupported)" {
    // Failure path: the resolver can't materialize Records as raw bytes.
    // PutStdout in non-attrs mode must surface this as Failure, not
    // panic — exercising the errors-as-values discipline.
    var store = MemoryContentStore()
    var proc = PutStdout("raw", store)
    var schema = schemaFromFields("test", List<Field>[])
    var records = List<GenericRecord>[]
    var ff = FlowFile("ff-records", Map<String, String>{}, Records(schema, records), 0)
    var result = proc.process(ff)

    match (result) {
        case Failure(reason, failFf) {
            asserts.equalString(t, failFf.id, "ff-records")
            asserts.contains(t, reason, "Records")
        }
        case _ { t.Errorf("expected Failure for Records content, got %v", result) }
    }
}

test "ConvertCSVToRecord — parses header+rows into records" {
    var store = MemoryContentStore()
    var proc = ConvertCSVToRecord("csv", ",", true, store)
    var csvData = "name,age\nalice,30\nbob,25\n"
    var ff = createFlowFile(csvData.toBytes(), Map<String, String>{})
    var result = proc.process(ff)

    match (result) {
        case Single(out) {
            asserts.isTrue(t, isRecord(out.content), "content is records")
            match (out.content) {
                case Records(schema, rows) {
                    asserts.equalInt(t, len(schema.fields), 2)
                    asserts.equalString(t, schema.fields[0].name, "name")
                    asserts.equalString(t, schema.fields[1].name, "age")
                    asserts.equalInt(t, len(rows), 2)
                    asserts.equalString(t, fmt.Sprint(rows[0].getField("name")), "alice")
                    asserts.equalString(t, fmt.Sprint(rows[1].getField("age")), "25")
                }
                case _ { t.Errorf("expected Records") }
            }
        }
        case _ { t.Errorf("expected Single, got %v", result) }
    }
}

test "ConvertCSVToRecord — hasHeader=false auto-names columns" {
    var store = MemoryContentStore()
    var proc = ConvertCSVToRecord("csv", ",", false, store)
    var csvData = "x,y,z\n1,2,3\n"
    var ff = createFlowFile(csvData.toBytes(), Map<String, String>{})
    match (proc.process(ff)) {
        case Single(out) {
            match (out.content) {
                case Records(schema, rows) {
                    asserts.equalString(t, schema.fields[0].name, "col_0")
                    asserts.equalString(t, schema.fields[2].name, "col_2")
                    asserts.equalInt(t, len(rows), 2)
                }
                case _ { t.Errorf("expected Records") }
            }
        }
        case _ { t.Errorf("expected Single") }
    }
}

test "ConvertCSVToRecord — empty input returns Failure" {
    var store = MemoryContentStore()
    var proc = ConvertCSVToRecord("csv", ",", true, store)
    var ff = createFlowFile("".toBytes(), Map<String, String>{})
    match (proc.process(ff)) {
        case Failure(_, _) {}
        case _ { t.Errorf("expected Failure on empty input") }
    }
}

test "ConvertRecordToCSV — emits header + rows" {
    var fields = List<Field>[Field("name", STRING, null), Field("age", STRING, null)]
    var schema = schemaFromFields("test", fields)
    var rec1 = GenericRecord(schema)
    rec1.setField("name", "alice")
    rec1.setField("age", "30")
    var rec2 = GenericRecord(schema)
    rec2.setField("name", "bob")
    rec2.setField("age", "25")
    var ff = FlowFile("ff-csv", Map<String, String>{},
        Records(schema, List<GenericRecord>[rec1, rec2]), 0)

    var proc = ConvertRecordToCSV(",", true)
    match (proc.process(ff)) {
        case Single(out) {
            match (out.content) {
                case Raw(data) {
                    var s = string(data)
                    asserts.contains(t, s, "name,age")
                    asserts.contains(t, s, "alice,30")
                    asserts.contains(t, s, "bob,25")
                }
                case _ { t.Errorf("expected Raw") }
            }
        }
        case _ { t.Errorf("expected Single") }
    }
}

test "ConvertRecordToCSV — round-trip via ConvertCSVToRecord" {
    var fields = List<Field>[Field("a", STRING, null), Field("b", STRING, null)]
    var schema = schemaFromFields("rt", fields)
    var rec = GenericRecord(schema)
    rec.setField("a", "hello")
    rec.setField("b", "world")
    var ff = FlowFile("ff-rt", Map<String, String>{},
        Records(schema, List<GenericRecord>[rec]), 0)

    var toCsv = ConvertRecordToCSV(",", true)
    match (toCsv.process(ff)) {
        case Single(csvFf) {
            var fromCsv = ConvertCSVToRecord("rt", ",", true, MemoryContentStore())
            match (fromCsv.process(csvFf)) {
                case Single(roundTripped) {
                    match (roundTripped.content) {
                        case Records(_, rows) {
                            asserts.equalInt(t, len(rows), 1)
                            asserts.equalString(t, fmt.Sprint(rows[0].getField("a")), "hello")
                            asserts.equalString(t, fmt.Sprint(rows[0].getField("b")), "world")
                        }
                        case _ { t.Errorf("expected Records after round-trip") }
                    }
                }
                case _ { t.Errorf("CSV→Record step failed") }
            }
        }
        case _ { t.Errorf("Record→CSV step failed") }
    }
}

test "PackageFlowFileV3 — wraps FF in V3 envelope with mime attr" {
    var store = MemoryContentStore()
    var attrs = Map<String, String>{}
    attrs["env"] = "dev"
    var ff = createFlowFile("hello".toBytes(), attrs)
    var proc = PackageFlowFileV3(store)
    match (proc.process(ff)) {
        case Single(out) {
            asserts.equalString(t, out.attributes["mime.type"], "application/flowfile-v3")
            asserts.equalString(t, out.attributes["v3.original.id"], ff.id)
            match (out.content) {
                case Raw(data) {
                    asserts.isTrue(t, len(data) > V3_MAGIC_LEN, "packed body has body beyond magic")
                    var magic = "NiFiFF3".toBytes()
                    asserts.isTrue(t, bytes.Equal(data[0:V3_MAGIC_LEN], magic), "starts with V3 magic")
                }
                case _ { t.Errorf("expected Raw content") }
            }
        }
        case _ { t.Errorf("expected Single") }
    }
}

test "UnpackageFlowFileV3 — round-trip via PackageFlowFileV3" {
    var store = MemoryContentStore()
    var attrs = Map<String, String>{}
    attrs["env"] = "prod"
    attrs["app"] = "billing"
    var original = createFlowFile("payload-bytes".toBytes(), attrs)

    var pkg = PackageFlowFileV3(store)
    match (pkg.process(original)) {
        case Single(packed) {
            var unpkg = UnpackageFlowFileV3(store)
            match (unpkg.process(packed)) {
                case Single(restored) {
                    asserts.equalString(t, restored.attributes["env"], "prod")
                    asserts.equalString(t, restored.attributes["app"], "billing")
                    match (restored.content) {
                        case Raw(data) {
                            asserts.equalString(t, string(data), "payload-bytes")
                        }
                        case _ { t.Errorf("expected Raw on restored") }
                    }
                }
                case _ { t.Errorf("expected Single from unpkg") }
            }
        }
        case _ { t.Errorf("expected Single from pkg") }
    }
}

test "UnpackageFlowFileV3 — invalid magic returns Failure" {
    var store = MemoryContentStore()
    var ff = createFlowFile("not-a-v3-payload-just-text".toBytes(), Map<String, String>{})
    var proc = UnpackageFlowFileV3(store)
    match (proc.process(ff)) {
        case Failure(reason, _) {
            asserts.contains(t, reason, "V3")
        }
        case _ { t.Errorf("expected Failure on garbage input") }
    }
}

test "UnpackageFlowFileV3 — Records content rejected" {
    var store = MemoryContentStore()
    var schema = schemaFromFields("test", List<Field>[])
    var ff = FlowFile("ff-rec", Map<String, String>{}, Records(schema, List<GenericRecord>[]), 0)
    var proc = UnpackageFlowFileV3(store)
    match (proc.process(ff)) {
        case Failure(_, _) {}
        case _ { t.Errorf("expected Failure on Records content") }
    }
}

