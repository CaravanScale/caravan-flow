// Core tests: FlowFile, Content sealed type, ContentStore, V3 serde.
// Migrated from the pre-zinc-test test_main.zn; each `fn testFoo()` became
// a `test "foo"` block, and custom assert helpers were swapped for
// stdlib.asserts which reports through *testing.T.

import core
import fabric/model
import stdlib/asserts

// --- FlowFile ---

test "FlowFile basics — create, withAttribute, withContent" {
    Map<String, String> attrs = {"type": "order", "source": "test"}
    var ff = createFlowFile("hello".toBytes(), attrs)
    asserts.isTrue(t, ff.id.startsWith("ff-"), "id starts with ff-")
    asserts.equalString(t, ff.attributes["type"], "order")
    asserts.equalString(t, ff.attributes["source"], "test")

    var ff2 = withAttribute(ff, "env", "dev")
    asserts.equalString(t, ff2.attributes["env"], "dev")
    asserts.isTrue(t, ff2.id == ff.id, "same id after withAttribute")
    asserts.equalString(t, ff2.attributes["type"], "order")

    var ff3 = withContent(ff, Raw("new data".toBytes()))
    asserts.isTrue(t, ff3.id == ff.id, "same id after withContent")
}

// --- Content sealed type ---

test "Content types — Raw, Records, Claim" {
    var raw = Raw("data".toBytes())
    asserts.isFalse(t, isRecord(raw), "raw is not record")
    asserts.equalInt(t, int(contentSize(raw)), 4)

    var schema = schemaFromFields("test", List<Field>[])
    var rec = Records(schema, List<GenericRecord>[])
    asserts.isTrue(t, isRecord(rec), "records is record")

    var claim = Claim("claim-1", long(1024))
    asserts.isFalse(t, isRecord(claim), "claim is not record")
    asserts.equalInt(t, int(contentSize(claim)), 1024)
}

// --- ContentStore ---

test "ContentStore — store, retrieve, delete, maybeOffload, resolve" {
    var store = MemoryContentStore()
    var claimId = store.store("hello world".toBytes())
    asserts.isTrue(t, claimId != "", "claim id not empty")
    asserts.isTrue(t, store.exists(claimId), "claim exists")

    var retrieved = store.retrieve(claimId)
    asserts.equalString(t, string(retrieved), "hello world")

    store.delete(claimId)
    asserts.isFalse(t, store.exists(claimId), "deleted claim gone")

    var smallContent = maybeOffload(store, "small".toBytes())
    asserts.isTrue(t, !isRecord(smallContent), "small stays raw")

    var resolved = resolve(store, Raw("test".toBytes()))
    asserts.equalString(t, string(resolved.data), "test")
    asserts.equalString(t, resolved.errorMsg, "")
}

test "resolve errors — missing claim, records unresolvable, roundtrip" {
    var store = MemoryContentStore()

    var resolved = resolve(store, Claim("nonexistent", long(100)))
    asserts.equalInt(t, len(resolved.data), 0)

    var schema = schemaFromFields("test", List<Field>[])
    var resolvedRec = resolve(store, Records(schema, List<GenericRecord>[]))
    asserts.isTrue(t, resolvedRec.errorMsg != "", "records resolve has error")

    var claimId = store.store("claimed data".toBytes())
    var resolvedClaim = resolve(store, Claim(claimId, long(12)))
    asserts.equalString(t, string(resolvedClaim.data), "claimed data")
    asserts.equalString(t, resolvedClaim.errorMsg, "")
}

// --- V3 (NiFi FlowFile V3) serde ---

test "V3 roundtrip — single FlowFile, attributes and content preserved" {
    Map<String, String> attrs = {"filename": "test.txt", "type": "doc"}
    var ff = createFlowFile("Hello, NiFi!".toBytes(), attrs)

    var store = MemoryContentStore()
    var resolved = resolve(store, ff.content)
    var packed = packFlowFile(ff, resolved.data)
    asserts.isTrue(t, len(packed) > 0, "packed not empty")
    asserts.equalString(t, string(packed[0:7]), "NiFiFF3")

    var result = unpackFlowFile(packed, 0)
    asserts.equalString(t, result.errorMsg, "")
    asserts.equalString(t, result.ff.attributes["filename"], "test.txt")
    asserts.equalString(t, result.ff.attributes["type"], "doc")

    var resolvedBack = resolve(store, result.ff.content)
    asserts.equalString(t, string(resolvedBack.data), "Hello, NiFi!")
}

test "V3 multiple roundtrip — two FlowFiles preserve order and attrs" {
    var ff1 = createFlowFile("first".toBytes(), Map<String, String>{"index": "1"})
    var ff2 = createFlowFile("second".toBytes(), Map<String, String>{"index": "2"})

    var store = MemoryContentStore()
    var r1 = resolve(store, ff1.content)
    var r2 = resolve(store, ff2.content)

    var packed = packMultiple(
        List<FlowFile>[ff1, ff2],
        List<byte[]>[r1.data, r2.data]
    )

    var all = unpackAll(packed)
    asserts.equalInt(t, len(all), 2)
    asserts.equalString(t, all[0].attributes["index"], "1")
    asserts.equalString(t, all[1].attributes["index"], "2")
}

test "V3 empty attributes — zero-attr FlowFile roundtrips" {
    var ff = createFlowFile("payload".toBytes(), Map<String, String>{})
    var store = MemoryContentStore()
    var resolved = resolve(store, ff.content)
    var packed = packFlowFile(ff, resolved.data)

    var result = unpackFlowFile(packed, 0)
    asserts.equalString(t, result.errorMsg, "")
    asserts.equalInt(t, len(result.ff.attributes), 0)

    var resolvedBack = resolve(store, result.ff.content)
    asserts.equalString(t, string(resolvedBack.data), "payload")
}

test "V3 empty content — empty-bytes FlowFile survives roundtrip" {
    var ff = createFlowFile(byte[0], Map<String, String>{"tag": "empty"})
    var store = MemoryContentStore()
    var resolved = resolve(store, ff.content)
    var packed = packFlowFile(ff, resolved.data)

    var result = unpackFlowFile(packed, 0)
    asserts.equalString(t, result.errorMsg, "")
    asserts.equalString(t, result.ff.attributes["tag"], "empty")

    var resolvedBack = resolve(store, result.ff.content)
    asserts.equalInt(t, len(resolvedBack.data), 0)
}
