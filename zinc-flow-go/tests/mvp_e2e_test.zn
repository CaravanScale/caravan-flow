// Phase 2 MVP end-to-end test.
//
// Wires the full pipeline programmatically — same shape as the shared
// YAML fixture (examples/mvp-pipeline.yaml), but test-driven. Asserts
// that a single poll cycle through GenerateFlowFile produces the
// expected attribute stamping and routing behavior all the way to the
// terminal PutStdout-equivalent sink.
//
// The "PutStdout" slot is replaced with a RecordSink (already defined
// in fabric_test.zn) so we can assert WHAT ended up at the terminal
// instead of scraping stdout. Asserting at the sink is both cleaner
// and more stable against any future PutStdout format tweaks.
//
// The YAML-based smoke test lives separately and runs the Zinc binary
// + csharp binary in CI (Phase 5); this test covers the in-process
// behavior.

import core
import fabric.registry
import fabric.runtime
import fabric.source
import processors
import stdlib.asserts

test "MVP pipeline e2e — generate → update → route → sink" {
    // Wire fabric with MVP processors.
    var ctx = mkContext()
    var reg = Registry()
    registerBuiltins(reg)
    var fab = Fabric(reg, ctx)

    // Processor graph mirrors examples/mvp-pipeline.yaml.
    fab.addProcessor("tag-stage", "UpdateAttribute",
        Map<String, String>{"key": "stage", "value": "processed"})
    fab.addProcessor("router", "RouteOnAttribute",
        Map<String, String>{"routes": "dev: env EQ dev; prod: env EQ prod"})

    // Terminal sinks — swap RecordSink in for PutStdout so we can see
    // exactly what landed on each branch.
    var devSink = RecordSink("dev")
    var prodSink = RecordSink("prod")
    var unmatchedSink = RecordSink("unmatched")
    fab.addProcessorInstance("stdout-dev", devSink, List<String>[])
    fab.addProcessorInstance("stdout-prod", prodSink, List<String>[])
    fab.addProcessorInstance("stdout-unmatched", unmatchedSink, List<String>[])

    // Wire graph.
    fab.connect("tag-stage", "success", List<String>["router"])
    fab.connect("router", "dev", List<String>["stdout-dev"])
    fab.connect("router", "prod", List<String>["stdout-prod"])
    fab.connect("router", "unmatched", List<String>["stdout-unmatched"])
    fab.computeEntryPoints()

    // Drive from the source side — one poll cycle, three FlowFiles.
    var src = GenerateFlowFile("gen", 0, "ping", "text/plain", "env:dev", 3)
    var batch = src.pollOnce()
    asserts.equalInt(t, len(batch), 3)
    for (ff in batch) {
        fab.execute(ff, "tag-stage")
    }

    // All three FlowFiles stamped env=dev → all land at dev sink.
    asserts.equalInt(t, devSink.count(), 3)
    asserts.equalInt(t, prodSink.count(), 0)
    asserts.equalInt(t, unmatchedSink.count(), 0)

    // Each must carry stage=processed from UpdateAttribute and the
    // source-baked env=dev.
    for (ff in devSink.captured) {
        asserts.equalString(t, ff.attributes["stage"], "processed")
        asserts.equalString(t, ff.attributes["env"], "dev")
        asserts.equalString(t, ff.attributes["source"], "gen")
    }
}

// Shared YAML fixture lives at examples/mvp-pipeline.yaml. The
// cross-binary interop gate — running the exact same YAML on the
// Zinc binary and the csharp binary and asserting byte-identical
// output for the same FlowFile inputs — is Phase 5 work. That needs
// a CI runner that can spin up both binaries, so we keep it out of
// the in-process test suite. The programmatic tests above assert the
// same graph topology, connection keys, and processor types as the
// YAML; any drift shows up there first.

test "MVP pipeline e2e — prod traffic lands on prod branch, dev stays empty" {
    var ctx = mkContext()
    var reg = Registry()
    registerBuiltins(reg)
    var fab = Fabric(reg, ctx)

    fab.addProcessor("tag-stage", "UpdateAttribute",
        Map<String, String>{"key": "stage", "value": "processed"})
    fab.addProcessor("router", "RouteOnAttribute",
        Map<String, String>{"routes": "dev: env EQ dev; prod: env EQ prod"})

    var devSink = RecordSink("dev")
    var prodSink = RecordSink("prod")
    fab.addProcessorInstance("stdout-dev", devSink, List<String>[])
    fab.addProcessorInstance("stdout-prod", prodSink, List<String>[])

    fab.connect("tag-stage", "success", List<String>["router"])
    fab.connect("router", "dev", List<String>["stdout-dev"])
    fab.connect("router", "prod", List<String>["stdout-prod"])
    fab.computeEntryPoints()

    // Source stamped env=prod.
    var src = GenerateFlowFile("gen-prod", 0, "ping", "", "env:prod", 2)
    var batch = src.pollOnce()
    for (ff in batch) {
        fab.execute(ff, "tag-stage")
    }

    asserts.equalInt(t, devSink.count(), 0)
    asserts.equalInt(t, prodSink.count(), 2)
}
