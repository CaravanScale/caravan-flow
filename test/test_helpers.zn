// Test helpers — assertion utilities for zinc-flow tests.
// MemoryContentStore is in core/contentstore.zn (production code, not test-only).

import core

// testContext creates a ProcessorContext backed by MemoryContentStore.
pub fn testContext(): ProcessorContext {
    var store = MemoryContentStore()
    var cp = ContentProvider("content", store)
    cp.enable()
    var ctx = ProcessorContext()
    ctx.addProvider(cp)
    return ctx
}

// testScopedContext creates a ScopedContext with a content provider.
pub fn testScopedContext(): ScopedContext {
    var store = MemoryContentStore()
    var cp = ContentProvider("content", store)
    cp.enable()
    var providers = Map<String, Provider>{}
    providers["content"] = cp
    return ScopedContext(providers)
}

// assertEqual prints PASS or FAIL for a string comparison.
pub fn assertEqual(String label, String actual, String expected) {
    if actual == expected {
        print("  PASS: ${label}")
    } else {
        print("  FAIL: ${label} — expected '${expected}', got '${actual}'")
    }
}

// assertTrue prints PASS or FAIL for a boolean check.
pub fn assertTrue(String label, bool value) {
    if value {
        print("  PASS: ${label}")
    } else {
        print("  FAIL: ${label} — expected true")
    }
}

// assertFalse prints PASS or FAIL for a boolean check.
pub fn assertFalse(String label, bool value) {
    if !value {
        print("  PASS: ${label}")
    } else {
        print("  FAIL: ${label} — expected false")
    }
}

// assertIntEqual prints PASS or FAIL for an int comparison.
pub fn assertIntEqual(String label, int actual, int expected) {
    if actual == expected {
        print("  PASS: ${label}")
    } else {
        print("  FAIL: ${label} — expected ${expected}, got ${actual}")
    }
}

// JSON test data — single-quoted strings are literal (no interpolation).

pub fn testJsonArray(): byte[] {
    return '[{"name": "Alice", "amount": 42}]'.toBytes()
}

pub fn testJsonGeo(): byte[] {
    return '[{"city": "Portland"}]'.toBytes()
}
