// Test: FlowFile creation, attribute manipulation, Content types

import core

fn main() {
    // Create FlowFile with Raw content
    Map<String, String> attrs = {"type": "order", "source": "test"}
    var ff = createFlowFile("hello world".toBytes(), attrs)
    print("id starts with ff-: {ff.id.startsWith("ff-")}")
    print("type: {ff.attributes["type"]}")
    print("source: {ff.attributes["source"]}")

    // withAttribute creates a copy
    var ff2 = withAttribute(ff, "env", "dev")
    print("ff2 env: {ff2.attributes["env"]}")
    print("ff2 same id: {ff2.id == ff.id}")

    // Content types
    var raw = Raw("data".toBytes())
    print("isRecord raw: {isRecord(raw)}")

    var schema = schemaFromFields("test", List<Field>[])
    var records = Records(schema, List<GenericRecord>[])
    print("isRecord records: {isRecord(records)}")

    var claim = Claim("claim-123", long(1024))
    print("isRecord claim: {isRecord(claim)}")

    // contentSize
    print("raw size: {contentSize(Raw("abcde".toBytes()))}")
    print("claim size: {contentSize(Claim("x", long(256000)))}")

    // createFlowFileWithContent
    var ff3 = createFlowFileWithContent(Raw("test".toBytes()), Map<String, String>{})
    print("ff3 has content: true")

    print("test_flowfile OK")
}
