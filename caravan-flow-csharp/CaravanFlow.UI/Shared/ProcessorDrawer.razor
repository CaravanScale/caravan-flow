@inject FlowApiClient Api
@using System.Text.Json
@using System.Text.Json.Nodes

@*
    ProcessorDrawer — slide-in panel anchored right of the graph.

    Edits are applied to the live runtime graph via the management
    API; they don't touch config.yaml. The operator uses the
    top-level "Save to config" button to persist everything (slice 3d).

    Dirty-state semantics:
      - Initial view-model is built once from the Processor parameter.
      - Input changes flip _dirty = true; upstream topology refreshes
        are queued and displayed as a banner, but the form is NOT
        overwritten until the operator saves or discards.
*@

@if (Processor is not null && Processor.Value.ValueKind == JsonValueKind.Object)
{
    <aside class="drawer open">
        <header>
            <div>
                <strong class="mono">@_name</strong>
                <span class="pill @StateClass">@_state</span>
            </div>
            <button class="drawer-close" @onclick="OnCloseRequested" title="close">×</button>
        </header>

        @if (_upstreamQueued)
        {
            <div class="drawer-banner">
                upstream changed — <button class="link" @onclick="DiscardAndReload">discard edits</button> to refresh
            </div>
        }

        <nav class="drawer-tabs">
            <button class="@(_tab == Tab.Config ? "active" : "")" @onclick="() => _tab = Tab.Config">Config</button>
            <button class="@(_tab == Tab.Connections ? "active" : "")" @onclick="() => _tab = Tab.Connections">Connections</button>
            <button class="@(_tab == Tab.Stats ? "active" : "")" @onclick="() => _tab = Tab.Stats">Stats</button>
        </nav>

        <div class="drawer-body">
            @if (_tab == Tab.Config) { @ConfigTab }
            else if (_tab == Tab.Connections) { @ConnectionsTab }
            else { @StatsTab }
        </div>

        <footer class="drawer-footer">
            <button class="btn-danger" @onclick="RemoveProcessor" disabled="@_busy" title="remove from runtime">delete</button>
            <button @onclick="ToggleEnabled" disabled="@_busy">@(_state == "ENABLED" ? "disable" : "enable")</button>
            <div class="spacer"></div>
            @if (_status is not null) { <span class="muted">@_status</span> }
        </footer>
    </aside>
}

@code {
    [Parameter, EditorRequired] public JsonElement? Processor { get; set; }
    [Parameter, EditorRequired] public IReadOnlyList<string> AllProcessorNames { get; set; } = Array.Empty<string>();
    [Parameter, EditorRequired] public IReadOnlyList<string> EntryPoints { get; set; } = Array.Empty<string>();
    [Parameter] public EventCallback OnClose { get; set; }
    [Parameter] public EventCallback OnChanged { get; set; }

    private enum Tab { Config, Connections, Stats }
    private Tab _tab = Tab.Config;

    private string _name = "";
    private string _type = "";
    private string _state = "";
    private bool _isEntry;
    private List<ConfigRow> _config = new();
    private List<ConnRow> _connections = new();
    private JsonElement? _stats;

    private bool _dirty;
    private bool _busy;
    private bool _upstreamQueued;
    private string? _status;
    private JsonElement? _lastProcessor;

    private string StateClass => _state switch
    {
        "ENABLED" => "enabled",
        "STOPPED" => "stopped",
        _ => "disabled",
    };

    private sealed class ConfigRow { public string Key = ""; public string Value = ""; }
    private sealed class ConnRow { public string Rel = ""; public string Target = ""; }

    protected override void OnParametersSet()
    {
        if (Processor is null || Processor.Value.ValueKind != JsonValueKind.Object) return;

        // If the operator is mid-edit and a different processor arrives,
        // re-hydrate — the drawer is being pointed at a new node.
        // For same-node upstream refreshes while dirty, queue the
        // update and leave the form alone.
        var sameNode = _lastProcessor is not null && GetName(_lastProcessor.Value) == GetName(Processor.Value);
        if (_dirty && sameNode)
        {
            _upstreamQueued = true;
            _lastProcessor = Processor;
            return;
        }

        Hydrate(Processor.Value);
        _lastProcessor = Processor;
    }

    private void Hydrate(JsonElement p)
    {
        _name = GetName(p);
        _type = p.TryGetProperty("type", out var t) && t.ValueKind == JsonValueKind.String ? t.GetString()! : "";
        _state = p.TryGetProperty("state", out var s) && s.ValueKind == JsonValueKind.String ? s.GetString()! : "";
        _isEntry = EntryPoints.Contains(_name);

        _config = new List<ConfigRow>();
        if (p.TryGetProperty("config", out var cfg) && cfg.ValueKind == JsonValueKind.Object)
        {
            foreach (var kv in cfg.EnumerateObject())
                _config.Add(new ConfigRow { Key = kv.Name, Value = JsonValueToString(kv.Value) });
        }

        _connections = new List<ConnRow>();
        if (p.TryGetProperty("connections", out var c) && c.ValueKind == JsonValueKind.Object)
        {
            foreach (var rel in c.EnumerateObject())
            {
                if (rel.Value.ValueKind != JsonValueKind.Array) continue;
                foreach (var tgt in rel.Value.EnumerateArray())
                    if (tgt.ValueKind == JsonValueKind.String)
                        _connections.Add(new ConnRow { Rel = rel.Name, Target = tgt.GetString()! });
            }
        }

        _stats = p.TryGetProperty("stats", out var st) ? st : null;
        _dirty = false;
        _upstreamQueued = false;
        _status = null;
    }

    private static string GetName(JsonElement p) =>
        p.TryGetProperty("name", out var n) && n.ValueKind == JsonValueKind.String ? n.GetString()! : "";

    private static string JsonValueToString(JsonElement v) => v.ValueKind switch
    {
        JsonValueKind.String => v.GetString() ?? "",
        JsonValueKind.Number => v.ToString(),
        JsonValueKind.True => "true",
        JsonValueKind.False => "false",
        JsonValueKind.Null => "",
        _ => v.ToString(),
    };

    private RenderFragment ConfigTab => __builder =>
    {
        <div class="form">
            <label class="check">
                <input type="checkbox" checked="@_isEntry"
                       @onchange="@(e => { _isEntry = (bool)e.Value!; _dirty = true; })" />
                entry point
            </label>

            <h4>type</h4>
            <div class="readonly mono">@_type</div>

            <h4>config</h4>
            @if (_config.Count == 0) { <p class="muted">no config keys</p> }
            @foreach (var row in _config)
            {
                <div class="kv-row">
                    <input class="mono" value="@row.Key" placeholder="key"
                           @onchange="@(e => { row.Key = e.Value?.ToString() ?? ""; _dirty = true; })" />
                    <input class="mono" value="@row.Value" placeholder="value"
                           @onchange="@(e => { row.Value = e.Value?.ToString() ?? ""; _dirty = true; })" />
                    <button class="btn-tiny" @onclick="() => RemoveConfigRow(row)" title="remove">×</button>
                </div>
            }
            <button @onclick="AddConfigRow" class="btn-ghost">+ add key</button>

            <div class="form-actions">
                <button class="btn-primary" @onclick="SaveConfig" disabled="@(!_dirty || _busy)">
                    @(_busy ? "saving…" : "apply to runtime")
                </button>
                @if (_dirty) { <button class="btn-ghost" @onclick="DiscardAndReload">discard</button> }
            </div>
        </div>
    };

    private RenderFragment ConnectionsTab => __builder =>
    {
        <div class="form">
            <h4>outbound</h4>
            @if (_connections.Count == 0) { <p class="muted">no outbound connections</p> }
            @foreach (var row in _connections)
            {
                <div class="kv-row">
                    <input class="mono" value="@row.Rel" placeholder="relationship"
                           @onchange="@(e => { row.Rel = e.Value?.ToString() ?? ""; _dirty = true; })" />
                    <select class="mono" value="@row.Target"
                            @onchange="@(e => { row.Target = e.Value?.ToString() ?? ""; _dirty = true; })">
                        <option value="">-- target --</option>
                        @foreach (var target in AllProcessorNames.Where(n => n != _name))
                        {
                            <option value="@target" selected="@(row.Target == target)">@target</option>
                        }
                    </select>
                    <button class="btn-tiny" @onclick="() => RemoveConnRow(row)" title="remove">×</button>
                </div>
            }
            <button @onclick="AddConnRow" class="btn-ghost">+ add connection</button>

            <div class="form-actions">
                <button class="btn-primary" @onclick="SaveConnections" disabled="@(!_dirty || _busy)">
                    @(_busy ? "saving…" : "apply to runtime")
                </button>
                @if (_dirty) { <button class="btn-ghost" @onclick="DiscardAndReload">discard</button> }
            </div>
        </div>
    };

    private RenderFragment StatsTab => __builder =>
    {
        <div class="form">
            @if (_stats is null) { <p class="muted">no stats reported</p> }
            else
            {
                <dl class="kv">
                @foreach (var kv in _stats.Value.EnumerateObject())
                {
                    <dt class="mono">@kv.Name</dt>
                    <dd class="mono">@JsonValueToString(kv.Value)</dd>
                }
                </dl>
            }
        </div>
    };

    private void AddConfigRow() { _config.Add(new ConfigRow()); _dirty = true; }
    private void RemoveConfigRow(ConfigRow row) { _config.Remove(row); _dirty = true; }
    private void AddConnRow() { _connections.Add(new ConnRow()); _dirty = true; }
    private void RemoveConnRow(ConnRow row) { _connections.Remove(row); _dirty = true; }

    private async Task SaveConfig()
    {
        _busy = true; _status = null;
        try
        {
            var cfgMap = _config
                .Where(r => !string.IsNullOrWhiteSpace(r.Key))
                .ToDictionary(r => r.Key, r => (object?)r.Value);
            var body = new Dictionary<string, object?> { ["type"] = _type, ["config"] = cfgMap };
            var resp = await Api.UpdateProcessorConfigAsync(_name, body);
            _status = resp.IsSuccessStatusCode ? "applied" : $"failed {(int)resp.StatusCode}";

            // Entry-point side-effect: update the list if the checkbox state
            // differs from the current entryPoints view.
            if (resp.IsSuccessStatusCode)
            {
                var currentIsEntry = EntryPoints.Contains(_name);
                if (currentIsEntry != _isEntry)
                {
                    var newEntries = _isEntry
                        ? EntryPoints.Concat(new[] { _name }).Distinct().ToList()
                        : EntryPoints.Where(n => n != _name).ToList();
                    await Api.SetEntryPointsAsync(newEntries);
                }
                _dirty = false;
                await OnChanged.InvokeAsync();
            }
        }
        catch (Exception ex) { _status = $"error: {ex.Message}"; }
        finally { _busy = false; }
    }

    private async Task SaveConnections()
    {
        _busy = true; _status = null;
        try
        {
            // Rebuild relationship → [targets] from rows. Blank rel/target
            // rows are dropped silently (treat as in-flight entry).
            var relMap = new Dictionary<string, List<string>>();
            foreach (var r in _connections)
            {
                if (string.IsNullOrWhiteSpace(r.Rel) || string.IsNullOrWhiteSpace(r.Target)) continue;
                if (!relMap.TryGetValue(r.Rel, out var list))
                {
                    list = new List<string>();
                    relMap[r.Rel] = list;
                }
                if (!list.Contains(r.Target)) list.Add(r.Target);
            }
            var resp = await Api.SetConnectionsAsync(_name, relMap);
            _status = resp.IsSuccessStatusCode ? "applied" : $"failed {(int)resp.StatusCode}";
            if (resp.IsSuccessStatusCode)
            {
                _dirty = false;
                await OnChanged.InvokeAsync();
            }
        }
        catch (Exception ex) { _status = $"error: {ex.Message}"; }
        finally { _busy = false; }
    }

    private async Task ToggleEnabled()
    {
        _busy = true; _status = null;
        try
        {
            var resp = _state == "ENABLED"
                ? await Api.DisableProcessorAsync(_name)
                : await Api.EnableProcessorAsync(_name);
            _status = resp.IsSuccessStatusCode ? "toggled" : $"failed {(int)resp.StatusCode}";
            if (resp.IsSuccessStatusCode) await OnChanged.InvokeAsync();
        }
        catch (Exception ex) { _status = $"error: {ex.Message}"; }
        finally { _busy = false; }
    }

    private async Task RemoveProcessor()
    {
        _busy = true; _status = null;
        try
        {
            var resp = await Api.RemoveProcessorAsync(_name);
            if (resp.IsSuccessStatusCode)
            {
                _status = "removed";
                await OnChanged.InvokeAsync();
                await OnClose.InvokeAsync();
            }
            else { _status = $"failed {(int)resp.StatusCode}"; }
        }
        catch (Exception ex) { _status = $"error: {ex.Message}"; }
        finally { _busy = false; }
    }

    private void DiscardAndReload()
    {
        if (Processor is not null && Processor.Value.ValueKind == JsonValueKind.Object)
            Hydrate(Processor.Value);
    }

    private async Task OnCloseRequested() => await OnClose.InvokeAsync();
}
