@inject FlowApiClient Api

<aside class="drawer open">
    <header>
        <div>
            <strong class="mono">@From</strong>
            <span class="arrow">→</span>
            <strong class="mono">@To</strong>
        </div>
        <button class="drawer-close" @onclick="OnCloseRequested" title="close">×</button>
    </header>

    <div class="drawer-body">
        <dl class="kv">
            <dt>relationship</dt><dd class="mono">@Relationship</dd>
            <dt>from</dt><dd class="mono">@From</dd>
            <dt>to</dt><dd class="mono">@To</dd>
        </dl>
        <p class="muted">Removing drops this single edge from the runtime graph. Use the source node's Connections tab for bulk rewiring.</p>

        <div class="form-actions">
            <button class="btn-danger" @onclick="RemoveEdge" disabled="@_busy">
                @(_busy ? "removing…" : "remove edge")
            </button>
            @if (_status is not null) { <span class="muted">@_status</span> }
        </div>
    </div>
</aside>

@code {
    [Parameter, EditorRequired] public string From { get; set; } = "";
    [Parameter, EditorRequired] public string Relationship { get; set; } = "";
    [Parameter, EditorRequired] public string To { get; set; } = "";
    [Parameter] public EventCallback OnClose { get; set; }
    [Parameter] public EventCallback OnChanged { get; set; }

    private bool _busy;
    private string? _status;

    private async Task RemoveEdge()
    {
        _busy = true; _status = null;
        try
        {
            var resp = await Api.RemoveConnectionAsync(From, Relationship, To);
            if (resp.IsSuccessStatusCode)
            {
                _status = "removed";
                await OnChanged.InvokeAsync();
                await OnClose.InvokeAsync();
            }
            else { _status = $"failed {(int)resp.StatusCode}"; }
        }
        catch (Exception ex) { _status = $"error: {ex.Message}"; }
        finally { _busy = false; }
    }

    private async Task OnCloseRequested() => await OnClose.InvokeAsync();
}
