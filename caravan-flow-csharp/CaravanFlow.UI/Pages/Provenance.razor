@page "/provenance"
@inject FlowApiClient Api
@implements IDisposable

<PageTitle>caravan-flow — provenance</PageTitle>

<h1>Provenance</h1>

<p class="muted">last @_n events (polls every 2 s)</p>

@if (_error is not null) { <p class="error">@_error</p> }
else if (_events is null) { <p>loading…</p> }
else
{
    <table class="kv">
        <thead><tr><th>timestamp</th><th>type</th><th>flowfile</th><th>component</th><th>details</th></tr></thead>
        <tbody>
        @foreach (var e in _events.Value.EnumerateArray())
        {
            <tr>
                <td>@e.GetProperty("timestamp").GetInt64()</td>
                <td>@e.GetProperty("type").GetString()</td>
                <td><a href="lineage/@e.GetProperty("flowfile").GetString()?.Replace("ff-", "")">@e.GetProperty("flowfile").GetString()</a></td>
                <td>@e.GetProperty("component").GetString()</td>
                <td>@e.GetProperty("details").GetString()</td>
            </tr>
        }
        </tbody>
    </table>
}

@code {
    private System.Text.Json.JsonElement? _events;
    private string? _error;
    private int _n = 100;
    private Timer? _timer;

    protected override async Task OnInitializedAsync()
    {
        await Refresh();
        _timer = new Timer(async _ => { await Refresh(); InvokeAsync(StateHasChanged); },
            null, TimeSpan.FromSeconds(2), TimeSpan.FromSeconds(2));
    }

    private async Task Refresh()
    {
        try { _events = await Api.GetProvenanceRecentAsync(_n); _error = null; }
        catch (Exception ex) { _error = ex.Message; }
    }

    public void Dispose() => _timer?.Dispose();
}
