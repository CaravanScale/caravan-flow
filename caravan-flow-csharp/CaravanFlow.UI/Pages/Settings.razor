@page "/settings"
@inject FlowApiClient Api
@using System.Text.Json

<PageTitle>caravan-flow — settings</PageTitle>

<h1>Settings</h1>

<p class="muted">overlay stack: base ← local ← secrets ← env</p>

@if (_error is not null) { <p class="error">@_error</p> }
else if (_overlays is null) { <p>loading…</p> }
else if (TryGetString(_overlays.Value, "error", out var overlayErr))
{
    @* Worker responded 200 OK with a shape like {"error":"…"} — common
       when the worker booted without a config loader attached. Treat
       this as a graceful fallback rather than a component crash. *@
    <p class="error">overlays: @overlayErr</p>
}
else
{
    <div class="overlay-grid">
        @foreach (var role in new[] { "base", "local", "secrets" })
        {
            var layer = FindLayer(_overlays.Value, role);
            <div class="overlay-card">
                <h3>@role</h3>
                @if (layer is null) { <p class="muted">not reported</p> }
                else
                {
                    <dl class="kv">
                        @if (layer.Value.TryGetProperty("present", out var pres))
                        { <dt>present</dt><dd>@pres.GetBoolean()</dd> }
                        @if (layer.Value.TryGetProperty("path", out var p))
                        { <dt>path</dt><dd class="mono">@p.GetString()</dd> }
                        @if (layer.Value.TryGetProperty("size", out var sz) && sz.ValueKind == JsonValueKind.Number)
                        { <dt>size</dt><dd>@sz.GetInt64() B</dd> }
                    </dl>
                }
            </div>
        }
    </div>

    <h2>Secrets editor</h2>
    <p class="muted">writes <code>secrets.yaml</code> via <code>PUT /api/overlays/secrets</code>. base + local are edit-via-git only.</p>
    <textarea class="yaml-edit" rows="12" @bind="_secretsYaml" placeholder="key: value"></textarea>
    <div>
        <button @onclick="SaveSecrets" disabled="@_saving">@(_saving ? "saving…" : "save secrets")</button>
        @if (_saveStatus is not null) { <span class="muted">@_saveStatus</span> }
    </div>
}

<h2>Version control</h2>
@if (_vc is null) { <p class="muted">loading…</p> }
else
{
    <dl class="kv">
        @if (_vc.Value.TryGetProperty("enabled", out var en))
        {
            <dt>enabled</dt><dd>@en.GetBoolean()</dd>
            @if (en.GetBoolean())
            {
                @if (_vc.Value.TryGetProperty("branch", out var b))
                { <dt>branch</dt><dd>@b.GetString()</dd> }
                @if (_vc.Value.TryGetProperty("clean", out var c) && (c.ValueKind == JsonValueKind.True || c.ValueKind == JsonValueKind.False))
                { <dt>clean</dt><dd>@c.GetBoolean()</dd> }
                @if (_vc.Value.TryGetProperty("ahead", out var a) && a.ValueKind == JsonValueKind.Number)
                { <dt>ahead</dt><dd>@a.GetInt32()</dd> }
                @if (_vc.Value.TryGetProperty("behind", out var bh) && bh.ValueKind == JsonValueKind.Number)
                { <dt>behind</dt><dd>@bh.GetInt32()</dd> }
            }
        }
        else
        {
            <dt>status</dt><dd class="muted">no enabled field in response</dd>
        }
    </dl>
}

@code {
    private JsonElement? _overlays;
    private JsonElement? _vc;
    private string? _error;
    private string _secretsYaml = "";
    private bool _saving;
    private string? _saveStatus;

    protected override async Task OnInitializedAsync()
    {
        try { _overlays = await Api.GetOverlaysAsync(); }
        catch (Exception ex) { _error = $"overlays: {ex.Message}"; }

        try { _vc = await Api.GetVcStatusAsync(); }
        catch (Exception ex) { _error = (_error is null ? "" : _error + " · ") + $"vc: {ex.Message}"; }
    }

    private async Task SaveSecrets()
    {
        _saving = true;
        _saveStatus = null;
        try
        {
            var resp = await Api.WriteSecretsAsync(new { yaml = _secretsYaml });
            _saveStatus = resp.IsSuccessStatusCode ? "saved" : $"failed: {(int)resp.StatusCode}";
        }
        catch (Exception ex) { _saveStatus = $"error: {ex.Message}"; }
        finally { _saving = false; }
    }

    private static bool TryGetString(JsonElement el, string prop, out string value)
    {
        value = "";
        if (el.ValueKind != JsonValueKind.Object) return false;
        if (!el.TryGetProperty(prop, out var v)) return false;
        if (v.ValueKind != JsonValueKind.String) return false;
        value = v.GetString() ?? "";
        return true;
    }

    private static JsonElement? FindLayer(JsonElement root, string role)
    {
        // Worker returns { layers: [{ role, path, present, size }, …] }.
        // Pick the layer whose "role" matches; null when missing so the
        // render can show a "not reported" placeholder instead.
        if (!root.TryGetProperty("layers", out var layers) || layers.ValueKind != JsonValueKind.Array)
            return null;
        foreach (var l in layers.EnumerateArray())
        {
            if (l.TryGetProperty("role", out var r) &&
                r.ValueKind == JsonValueKind.String &&
                r.GetString() == role)
                return l;
        }
        return null;
    }
}
