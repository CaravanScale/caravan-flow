@page "/"
@inject FlowApiClient Api
@inject IJSRuntime JS
@implements IDisposable
@using System.Text.Json
@using Microsoft.JSInterop

<PageTitle>caravan-flow — graph</PageTitle>

<div class="graph-header">
    <h1>Graph</h1>
    <p class="muted">
        @_processorCount processors · @_connectionCount connections ·
        @_entryPointCount entry points
        @if (_lastRenderTick is not null)
        { <text> · last layout @_lastRenderTick</text> }
    </p>
</div>

@if (_error is not null) { <p class="error">Failed to load: @_error</p> }

<div id="graph-canvas" class="graph-canvas">
    <p class="muted">loading…</p>
</div>

@if (_selectedNode is not null && _selectedProcessor is not null)
{
    <ProcessorDrawer Processor="_selectedProcessor"
                     AllProcessorNames="_allNames"
                     EntryPoints="_entryPointNames"
                     OnClose="CloseDrawer"
                     OnChanged="RefreshNow" />
}
else if (_selectedEdge is not null)
{
    <EdgeDrawer From="@_selectedEdge.Value.From"
                Relationship="@_selectedEdge.Value.Rel"
                To="@_selectedEdge.Value.To"
                OnClose="CloseDrawer"
                OnChanged="RefreshNow" />
}

@code {
    // Split-poll model:
    //   topology (/api/flow)          — every 15 s, re-renders SVG only when the fingerprint changes
    //   stats (/api/processor-stats)  — every 2 s, patches labels in place via caravanGraph.updateStats
    //   RefreshNow()                  — called after every operator mutation for zero-latency reconciliation
    //   visibility change             — both timers suspend while the tab is hidden

    private const int TopologyPollMs = 15_000;
    private const int StatsPollMs = 2_000;

    private JsonElement? _flow;
    private string _lastTopologyHash = "";
    private string? _error;
    private int _processorCount;
    private int _connectionCount;
    private int _entryPointCount;
    private string? _lastRenderTick;

    private string? _selectedNode;
    private JsonElement? _selectedProcessor;
    private EdgeSel? _selectedEdge;
    private IReadOnlyList<string> _allNames = Array.Empty<string>();
    private IReadOnlyList<string> _entryPointNames = Array.Empty<string>();

    private Timer? _topologyTimer;
    private Timer? _statsTimer;
    private DotNetObjectReference<Graph>? _selfRef;
    private bool _jsReady;
    private bool _paused;

    private readonly record struct EdgeSel(string From, string Rel, string To);

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;
        _selfRef = DotNetObjectReference.Create(this);
        _jsReady = true;

        try { await JS.InvokeVoidAsync("caravanGraph.onVisibilityChange", _selfRef); }
        catch (Exception ex) { Console.Error.WriteLine($"visibility wire failed: {ex.Message}"); }

        await RefreshTopology();
        _topologyTimer = new Timer(async _ => { if (!_paused) await RefreshTopology(); },
            null, TopologyPollMs, TopologyPollMs);
        _statsTimer = new Timer(async _ => { if (!_paused) await RefreshStats(); },
            null, StatsPollMs, StatsPollMs);
    }

    private async Task RefreshTopology()
    {
        try
        {
            var flow = await Api.GetFlowAsync();
            _flow = flow;
            _error = null;
            UpdateCounts(flow);

            var hash = await JS.InvokeAsync<string>("caravanGraph.hashTopology", flow);
            if (hash != _lastTopologyHash)
            {
                _lastTopologyHash = hash;
                _lastRenderTick = DateTime.Now.ToString("HH:mm:ss");
                await JS.InvokeVoidAsync("caravanGraph.render", "graph-canvas", flow, _selfRef);
                await InvokeAsync(StateHasChanged);
            }
        }
        catch (Exception ex)
        {
            _error = ex.Message;
            await InvokeAsync(StateHasChanged);
        }
    }

    private async Task RefreshStats()
    {
        try
        {
            var stats = await Api.GetProcessorStatsAsync();
            // Normalize from {processors: {name: {processed, errors}, …}} or {name: {…}, …}
            if (stats.ValueKind == JsonValueKind.Object &&
                stats.TryGetProperty("processors", out var nested) &&
                nested.ValueKind == JsonValueKind.Object)
            {
                stats = nested;
            }
            if (stats.ValueKind == JsonValueKind.Object)
            {
                await JS.InvokeVoidAsync("caravanGraph.updateStats", stats);
            }
        }
        catch
        {
            // Silent — stats polling must not spam errors if the worker briefly hiccups.
        }
    }

    private void UpdateCounts(JsonElement flow)
    {
        _processorCount = flow.TryGetProperty("processors", out var p) && p.ValueKind == JsonValueKind.Array
            ? p.GetArrayLength() : 0;
        _entryPointCount = flow.TryGetProperty("entryPoints", out var ep) && ep.ValueKind == JsonValueKind.Array
            ? ep.GetArrayLength() : 0;
        _connectionCount = 0;
        var names = new List<string>();
        if (flow.TryGetProperty("processors", out var ps) && ps.ValueKind == JsonValueKind.Array)
        {
            foreach (var proc in ps.EnumerateArray())
            {
                if (proc.TryGetProperty("name", out var n) && n.ValueKind == JsonValueKind.String)
                    names.Add(n.GetString()!);
                if (!proc.TryGetProperty("connections", out var c) || c.ValueKind != JsonValueKind.Object) continue;
                foreach (var rel in c.EnumerateObject())
                    if (rel.Value.ValueKind == JsonValueKind.Array) _connectionCount += rel.Value.GetArrayLength();
            }
        }
        _allNames = names;

        var entries = new List<string>();
        if (flow.TryGetProperty("entryPoints", out var eps) && eps.ValueKind == JsonValueKind.Array)
        {
            foreach (var e in eps.EnumerateArray())
                if (e.ValueKind == JsonValueKind.String) entries.Add(e.GetString()!);
        }
        _entryPointNames = entries;

        // If a drawer is open for a processor that now exists in the new
        // flow, refresh its Processor parameter so stats/state stay fresh.
        // (ProcessorDrawer's dirty-lock prevents overwriting in-flight edits.)
        if (_selectedNode is not null)
        {
            var p2 = FindProcessor(_selectedNode);
            if (p2 is not null) _selectedProcessor = p2;
            else CloseDrawer(); // processor was deleted out from under us
        }
    }

    [JSInvokable]
    public Task OnNodeClick(string name)
    {
        _selectedNode = name;
        _selectedEdge = null;
        _selectedProcessor = FindProcessor(name);
        StateHasChanged();
        return Task.CompletedTask;
    }

    [JSInvokable]
    public Task OnEdgeClick(string from, string rel, string to)
    {
        _selectedEdge = new EdgeSel(from, rel, to);
        _selectedNode = null;
        _selectedProcessor = null;
        StateHasChanged();
        return Task.CompletedTask;
    }

    [JSInvokable]
    public Task OnCanvasClick()
    {
        CloseDrawer();
        StateHasChanged();
        return Task.CompletedTask;
    }

    [JSInvokable]
    public Task OnVisibilityChange(string state)
    {
        _paused = state == "hidden";
        return Task.CompletedTask;
    }

    private void CloseDrawer()
    {
        _selectedNode = null;
        _selectedEdge = null;
        _selectedProcessor = null;
    }

    private async Task RefreshNow()
    {
        // Drawer-invoked after a successful mutation. Force an immediate
        // topology refresh so the graph reflects the change without
        // waiting on the 15 s timer.
        await RefreshTopology();
        await RefreshStats();
    }

    private JsonElement? FindProcessor(string name)
    {
        if (_flow is null) return null;
        if (!_flow.Value.TryGetProperty("processors", out var ps) || ps.ValueKind != JsonValueKind.Array) return null;
        foreach (var p in ps.EnumerateArray())
        {
            if (p.TryGetProperty("name", out var n) && n.ValueKind == JsonValueKind.String && n.GetString() == name)
                return p;
        }
        return null;
    }

    public void Dispose()
    {
        _topologyTimer?.Dispose();
        _statsTimer?.Dispose();
        _selfRef?.Dispose();
    }
}
