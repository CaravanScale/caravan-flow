@page "/metrics"
@inject FlowApiClient Api
@implements IDisposable

<PageTitle>caravan-flow — metrics</PageTitle>

<h1>Metrics</h1>

<p class="muted">Prometheus text exposition — polls every 5 s</p>

@if (_error is not null) { <p class="error">@_error</p> }
else if (_samples is null) { <p>loading…</p> }
else
{
    <table class="kv">
        <thead><tr><th>metric</th><th>labels</th><th>value</th></tr></thead>
        <tbody>
        @foreach (var s in _samples)
        {
            <tr>
                <td class="mono">@s.Name</td>
                <td class="mono">@s.Labels</td>
                <td class="num">@s.Value</td>
            </tr>
        }
        </tbody>
    </table>
}

@code {
    private List<Sample>? _samples;
    private string? _error;
    private Timer? _timer;

    protected override async Task OnInitializedAsync()
    {
        await Refresh();
        _timer = new Timer(async _ => { await Refresh(); await InvokeAsync(StateHasChanged); },
            null, TimeSpan.FromSeconds(5), TimeSpan.FromSeconds(5));
    }

    private async Task Refresh()
    {
        try
        {
            var raw = await Api.GetMetricsRawAsync();
            _samples = Parse(raw);
            _error = null;
        }
        catch (Exception ex) { _error = ex.Message; }
    }

    private static List<Sample> Parse(string text)
    {
        var list = new List<Sample>();
        foreach (var line in text.Split('\n'))
        {
            var l = line.Trim();
            if (l.Length == 0 || l[0] == '#') continue;
            // name{labels} value  OR  name value
            var braceOpen = l.IndexOf('{');
            string name, labels;
            int valueStart;
            if (braceOpen >= 0)
            {
                var braceClose = l.IndexOf('}', braceOpen);
                if (braceClose < 0) continue;
                name = l[..braceOpen];
                labels = l[(braceOpen + 1)..braceClose];
                valueStart = braceClose + 1;
            }
            else
            {
                var sp = l.IndexOf(' ');
                if (sp < 0) continue;
                name = l[..sp];
                labels = "";
                valueStart = sp;
            }
            var valueStr = l[valueStart..].Trim().Split(' ')[0];
            list.Add(new Sample(name, labels, valueStr));
        }
        return list;
    }

    public void Dispose() => _timer?.Dispose();

    private sealed record Sample(string Name, string Labels, string Value);
}
