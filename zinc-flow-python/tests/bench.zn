"""Throughput benchmark — measures flowfiles/sec through a 2-processor chain."""
import sys
import os
import time

sys.path.insert(0, os.path.join(os.path.dirname(__file__), "..", "src"))

from core.types import create_flowfile, ComponentState
from core.queue import FlowQueue
from core.dlq import DLQ
from core.session import ProcessSession
from core.context import ProcessorContext, ScopedContext
from core.providers import ContentProvider
from fabric.router import RulesEngine, RoutingRule, Operator
from fabric.registry import Registry
from processors.builtin import AddAttribute, register_builtins


def bench_session_throughput(n: int) {
    """Direct session.execute() — no HTTP, no async loops, pure engine throughput."""
    tag = AddAttribute("env", "prod")
    sink = AddAttribute("done", "true")

    tag_q = FlowQueue("tag", n + 100, 0, 30.0)
    sink_q = FlowQueue("sink", n + 100, 0, 30.0)
    queues = {"tag": tag_q, "sink": sink_q}

    tag_engine = RulesEngine()
    tag_engine.add_or_replace_ruleset("flow", [RoutingRule("to-sink", "env", Operator.EXISTS, "", "sink")])
    sink_engine = RulesEngine()

    dlq = DLQ()
    tag_session = ProcessSession(tag_q, tag, "tag", tag_engine, queues, dlq, 5)
    sink_session = ProcessSession(sink_q, sink, "sink", sink_engine, queues, dlq, 5)

    # Pre-load all flowfiles
    for i in range(n) {
        ff = create_flowfile(b"bench payload data here", {"type": "order", "id": str(i)})
        tag_q.offer(ff)
    }

    start = time.perf_counter()

    # Process all through tag -> sink
    for _ in range(n) {
        tag_session.execute()
    }
    for _ in range(n) {
        sink_session.execute()
    }

    elapsed = time.perf_counter() - start
    rate = n / elapsed
    print("  {n} flowfiles, 2 hops: {elapsed:.3f}s ({rate:,.0f} ff/s)")
    return rate
}


def bench_queue_throughput(n: int) {
    """Raw queue offer/claim/ack — measures lock overhead."""
    q = FlowQueue("bench", n + 100, 0, 30.0)

    start = time.perf_counter()
    for i in range(n) {
        ff = create_flowfile(b"x", {})
        q.offer(ff)
    }
    offer_time = time.perf_counter() - start

    start = time.perf_counter()
    for _ in range(n) {
        entry = q.claim()
        q.ack(entry.id)
    }
    claim_time = time.perf_counter() - start

    print("  {n} offer: {offer_time:.3f}s ({n/offer_time:,.0f} ops/s)")
    print("  {n} claim+ack: {claim_time:.3f}s ({n/claim_time:,.0f} ops/s)")
}


def main() {
    print("=== zinc-flow-python benchmark ===")
    print("")

    print("Queue throughput:")
    bench_queue_throughput(100_000)
    print("")

    print("Session throughput (2-hop pipeline):")
    bench_session_throughput(10_000)
    bench_session_throughput(50_000)
    bench_session_throughput(100_000)
}
