"""zinc-flow-python test suite — matches zinc-flow (Go) test coverage."""
import sys
import os
import time
import json
import logging

# Add src to path. Two layouts to cover:
#   • Source tree: tests/test_flow.zn lives at <repo>/tests/, src is sibling at <repo>/src/.
#   • zinc-python build:  tests/test_flow.py lives at <tmp>/tests/, modules sit at <tmp>/
#     directly because the build flattens src/* into the tmp root.
# Insert both so the import works regardless of which we're running under.
sys.path.insert(0, os.path.join(os.path.dirname(__file__), "..", "src"))
sys.path.insert(0, os.path.join(os.path.dirname(__file__), ".."))

from core.types import (
    FlowFile, Raw, Records, Claim, Single, Dropped, Failure,
    ComponentState, create_flowfile, with_attribute, with_content,
    content_size, is_record,
)
from core.queue import FlowQueue
from core.dlq import DLQ
from core.context import ProcessorContext, ScopedContext
from core.providers import ConfigProvider, LoggingProvider, ContentProvider
from core.session import ProcessSession
from fabric.router import RulesEngine, RoutingRule, Operator
from fabric.registry import Registry
from fabric.runtime import Fabric
from processors.builtin import (
    AddAttribute, LogProcessor, FileSink, JsonToRecords, RecordsToJson,
    register_builtins,
)

logging.basicConfig(level=logging.WARNING)

passed = 0
failed = 0


def assert_true(label: str, value: bool) {
    global passed, failed
    if value {
        print("  PASS: {label}")
        passed += 1
    } else {
        print("  FAIL: {label}")
        failed += 1
    }
}

def assert_false(label: str, value: bool) {
    assert_true(label, not value)
}

def assert_eq(label: str, actual, expected) {
    global passed, failed
    if actual == expected {
        print("  PASS: {label}")
        passed += 1
    } else {
        print("  FAIL: {label} — expected {expected}, got {actual}")
        failed += 1
    }
}


# --- Helpers ---

def test_context() -> ProcessorContext {
    ctx = ProcessorContext()
    cp = ContentProvider("content", None)
    cp.enable()
    ctx.add_provider(cp)
    lp = LoggingProvider()
    lp.enable()
    ctx.add_provider(lp)
    cfg_p = ConfigProvider({})
    cfg_p.enable()
    ctx.add_provider(cfg_p)
    return ctx
}

def test_scoped_context() -> ScopedContext {
    cp = ContentProvider("content", None)
    cp.enable()
    return ScopedContext({"content": cp})
}


# =============================================================================
# Core types
# =============================================================================

def test_flowfile_basics() {
    print("--- FlowFile Basics ---")
    ff = create_flowfile(b"hello", {"type": "order", "source": "test"})
    assert_true("id starts with ff-", ff.id.startswith("ff-"))
    assert_eq("type attr", ff.attributes["type"], "order")
    assert_eq("source attr", ff.attributes["source"], "test")

    ff2 = with_attribute(ff, "env", "dev")
    assert_eq("added env", ff2.attributes["env"], "dev")
    assert_true("same id after with_attribute", ff2.id == ff.id)
    assert_eq("original attrs preserved", ff2.attributes["type"], "order")

    ff3 = with_content(ff, Raw(b"new data"))
    assert_true("same id after with_content", ff3.id == ff.id)
}

def test_content_types() {
    print("--- Content Types ---")
    raw = Raw(b"data")
    assert_false("raw is not record", is_record(raw))
    assert_eq("raw size", content_size(raw), 4)

    rec = Records(schema={"type": "test"}, records=[])
    assert_true("records is record", is_record(rec))

    claim = Claim("claim-1", 1024)
    assert_false("claim is not record", is_record(claim))
    assert_eq("claim size", content_size(claim), 1024)
}


# =============================================================================
# Processors
# =============================================================================

def test_processor_add_attribute() {
    print("--- Processor: AddAttribute ---")
    proc = AddAttribute("env", "prod")
    ff = create_flowfile(b"data", {"type": "order"})
    result = proc.process(ff)
    assert_true("result is Single", isinstance(result, Single))
    assert_eq("added env", result.flowfile.attributes["env"], "prod")
    assert_eq("kept type", result.flowfile.attributes["type"], "order")
}

def test_processor_log_passthrough() {
    print("--- Processor: LogProcessor ---")
    proc = LogProcessor("test")
    ff = create_flowfile(b"data", {"type": "order"})
    result = proc.process(ff)
    assert_true("result is Single", isinstance(result, Single))
    assert_true("same id", result.flowfile.id == ff.id)
    assert_eq("same type", result.flowfile.attributes["type"], "order")
}

def test_processor_file_sink() {
    print("--- Processor: FileSink ---")
    os.makedirs("/tmp/zinc-flow-python-test/output", exist_ok=True)
    proc = FileSink("/tmp/zinc-flow-python-test/output", None)
    ff = create_flowfile(b"sink test", {})
    result = proc.process(ff)
    assert_true("result is Dropped", isinstance(result, Dropped))
}

def test_processor_json_to_records() {
    print("--- Processor: JsonToRecords ---")
    proc = JsonToRecords(None)
    data = json.dumps([{"name": "Alice"}, {"name": "Bob"}]).encode()
    ff = create_flowfile(data, {})
    result = proc.process(ff)
    assert_true("result is Single", isinstance(result, Single))
    assert_true("content is records", is_record(result.flowfile.content))
}

def test_processor_records_to_json() {
    print("--- Processor: RecordsToJson ---")
    content = Records(schema={"type": "test"}, records=[{"name": "Bob"}])
    ff = FlowFile(id="ff-test", attributes={}, content=content, size=1)
    proc = RecordsToJson()
    result = proc.process(ff)
    assert_true("result is Single", isinstance(result, Single))
    assert_false("output is raw not records", is_record(result.flowfile.content))
    assert_true("json contains Bob", b"Bob" in result.flowfile.content.data)
}

def test_processor_json_roundtrip() {
    print("--- Processor: JSON Roundtrip ---")
    content = Records(schema={"type": "geo"}, records=[{"city": "Portland"}])
    ff = FlowFile(id="ff-rt", attributes={}, content=content, size=1)

    # Records -> JSON
    to_json = RecordsToJson()
    step1 = to_json.process(ff)
    assert_true("step1 is raw", isinstance(step1, Single) and not is_record(step1.flowfile.content))
    assert_true("json contains Portland", b"Portland" in step1.flowfile.content.data)

    # JSON -> Records
    to_rec = JsonToRecords(None)
    step2 = to_rec.process(step1.flowfile)
    assert_true("step2 is records", isinstance(step2, Single) and is_record(step2.flowfile.content))
}

def test_processor_json_to_records_empty() {
    print("--- Processor: JsonToRecords Empty ---")
    proc = JsonToRecords(None)
    ff = create_flowfile(b"not json at all", {})
    result = proc.process(ff)
    assert_true("invalid json fails", isinstance(result, Failure))
}


# =============================================================================
# Routing Engine
# =============================================================================

def test_routing_eq() {
    print("--- Routing: EQ ---")
    engine = RulesEngine()
    engine.add_or_replace_ruleset("test", [RoutingRule("r1", "type", Operator.EQ, "order", "proc-1")])
    assert_eq("eq match count", len(engine.get_destinations({"type": "order"})), 1)
    assert_eq("eq match dest", engine.get_destinations({"type": "order"})[0], "proc-1")
    assert_eq("eq no match", len(engine.get_destinations({"type": "event"})), 0)
}

def test_routing_neq() {
    print("--- Routing: NEQ ---")
    engine = RulesEngine()
    engine.add_or_replace_ruleset("test", [RoutingRule("r1", "type", Operator.NEQ, "order", "proc-2")])
    assert_eq("neq match count", len(engine.get_destinations({"type": "event"})), 1)
    assert_eq("neq no match", len(engine.get_destinations({"type": "order"})), 0)
}

def test_routing_contains() {
    print("--- Routing: CONTAINS ---")
    engine = RulesEngine()
    engine.add_or_replace_ruleset("test", [RoutingRule("r1", "message", Operator.CONTAINS, "error", "dlq")])
    assert_eq("contains match", len(engine.get_destinations({"message": "got an error here"})), 1)
    assert_eq("contains no match", len(engine.get_destinations({"message": "all good"})), 0)
}

def test_routing_starts_ends_with() {
    print("--- Routing: STARTSWITH/ENDSWITH ---")
    engine = RulesEngine()
    engine.add_or_replace_ruleset("test", [
        RoutingRule("starts", "path", Operator.STARTSWITH, "/api", "api-proc"),
        RoutingRule("ends", "path", Operator.ENDSWITH, ".json", "json-proc"),
    ])
    assert_eq("both match", len(engine.get_destinations({"path": "/api/data.json"})), 2)
    dests = engine.get_destinations({"path": "/api/data.xml"})
    assert_eq("starts only", len(dests), 1)
    assert_eq("starts dest", dests[0], "api-proc")
}

def test_routing_exists() {
    print("--- Routing: EXISTS ---")
    engine = RulesEngine()
    engine.add_or_replace_ruleset("test", [RoutingRule("r1", "priority", Operator.EXISTS, "", "proc")])
    assert_eq("exists match", len(engine.get_destinations({"priority": "high"})), 1)
    assert_eq("exists no match", len(engine.get_destinations({"type": "order"})), 0)
}

def test_routing_no_match() {
    print("--- Routing: No Match ---")
    engine = RulesEngine()
    engine.add_or_replace_ruleset("test", [RoutingRule("r1", "type", Operator.EQ, "order", "proc-1")])
    assert_eq("missing attr no match", len(engine.get_destinations({"source": "test"})), 0)

    # Disabled rule
    engine.add_or_replace_ruleset("disabled-set", [RoutingRule("r2", "type", Operator.EQ, "order", "proc-2", enabled=False)])
    dests = engine.get_destinations({"type": "order"})
    assert_eq("disabled rule skipped", len(dests), 1)
    assert_eq("only enabled matched", dests[0], "proc-1")
}


# =============================================================================
# Queue
# =============================================================================

def test_queue_offer_claim() {
    print("--- FlowQueue: Offer/Claim ---")
    q = FlowQueue("test-q", 100, 1024 * 1024, 30.0)
    ff = create_flowfile(b"hello", {"key": "val"})
    assert_true("offer accepted", q.offer(ff))
    assert_eq("visible count", q.visible_count(), 1)
    assert_eq("invisible count", q.invisible_count(), 0)

    entry = q.claim()
    assert_true("claim non-empty", entry is not None)
    assert_eq("claimed flowfile id", entry.flowfile.id, ff.id)
    assert_eq("after claim visible", q.visible_count(), 0)
    assert_eq("after claim invisible", q.invisible_count(), 1)

    q.ack(entry.id)
    assert_eq("after ack visible", q.visible_count(), 0)
    assert_eq("after ack invisible", q.invisible_count(), 0)
}

def test_queue_backpressure() {
    print("--- FlowQueue: Backpressure ---")
    q = FlowQueue("bp-q", 2, 1024, 30.0)
    assert_true("first offer", q.offer(create_flowfile(b"a", {})))
    assert_true("second offer", q.offer(create_flowfile(b"b", {})))
    assert_false("third rejected (backpressure)", q.offer(create_flowfile(b"c", {})))
    assert_false("no capacity", q.has_capacity())
}

def test_queue_ack_nack() {
    print("--- FlowQueue: Ack/Nack ---")
    q = FlowQueue("an-q", 100, 1024 * 1024, 30.0)
    q.offer(create_flowfile(b"test", {}))
    entry = q.claim()
    assert_eq("attempt before nack", entry.attempt_count, 0)
    q.nack(entry.id)
    assert_eq("after nack visible", q.visible_count(), 1)
    assert_eq("after nack invisible", q.invisible_count(), 0)
    retried = q.claim()
    assert_eq("attempt after nack", retried.attempt_count, 1)
    q.ack(retried.id)
}


# =============================================================================
# DLQ
# =============================================================================

def test_dlq_add_and_list() {
    print("--- DLQ: Add/List ---")
    dlq = DLQ()
    assert_eq("initial count", dlq.count(), 0)
    ff = create_flowfile(b"failed", {"type": "test"})
    dlq.add(ff, "my-proc", "my-queue", 3, "processing error")
    assert_eq("after add count", dlq.count(), 1)
    entries = dlq.list_entries()
    assert_eq("list length", len(entries), 1)
    assert_eq("source processor", entries[0].source_processor, "my-proc")
    assert_eq("last error", entries[0].last_error, "processing error")
    assert_eq("attempt count", entries[0].attempt_count, 3)
}

def test_dlq_replay() {
    print("--- DLQ: Replay ---")
    dlq = DLQ()
    ff = create_flowfile(b"replay-me", {"id": "123"})
    dlq.add(ff, "proc", "queue", 5, "max retries")
    assert_eq("before replay", dlq.count(), 1)
    entries = dlq.list_entries()
    replayed = dlq.replay(entries[0].id)
    assert_eq("replayed flowfile id", replayed.id, ff.id)
    assert_eq("after replay", dlq.count(), 0)
}


