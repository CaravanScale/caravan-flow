def test_scoped_context_access() {
    print("--- ScopedContext: Access ---")
    cp = ContentProvider("content", None)
    cp.enable()
    ctx = ScopedContext({"content": cp})
    assert_eq("provider count", len(ctx.list_providers()), 1)
    p = ctx.get_provider("content")
    assert_eq("provider name", p.get_name(), "content")
}


# =============================================================================
# Provider Lifecycle
# =============================================================================

def test_provider_lifecycle() {
    print("--- Provider: Lifecycle ---")
    cp = ContentProvider("content", None)
    assert_false("initially disabled", cp.is_enabled())
    cp.enable()
    assert_true("after enable", cp.is_enabled())
    cp.disable(0)
    assert_false("after disable", cp.is_enabled())
    cp.enable()
    assert_true("re-enabled", cp.is_enabled())
    cp.shutdown()
    assert_false("after shutdown", cp.is_enabled())
}


# =============================================================================
# Fabric Integration
# =============================================================================

def test_fabric_multi_hop() {
    print("--- Fabric: Multi-Hop ---")
    ctx = test_context()
    reg = Registry()
    register_builtins(reg)
    fab = Fabric(reg, ctx)

    engine = RulesEngine()
    engine.add_or_replace_ruleset("flow", [
        RoutingRule("all-to-tag", "type", Operator.EXISTS, "", "tag-env"),
        RoutingRule("tagged-to-log", "env", Operator.EXISTS, "", "logger"),
    ])

    dests1 = engine.get_destinations({"type": "order"})
    assert_eq("first hop matches", len(dests1), 1)
    assert_eq("first hop dest", dests1[0], "tag-env")

    dests2 = engine.get_destinations({"type": "order", "env": "prod"})
    assert_eq("second hop matches", len(dests2), 2)

    ff = create_flowfile(b"multi-hop", {"type": "test"})
    assert_true("ingest accepted", fab.ingest(ff))
}

def test_fabric_dlq_from_failure() {
    print("--- Fabric: DLQ from Failure ---")
    ctx = test_context()
    reg = Registry()
    register_builtins(reg)
    fab = Fabric(reg, ctx)
    assert_eq("initial dlq", fab.dlq_store.count(), 0)
    ff = create_flowfile(b"test", {"type": "unknown"})
    assert_true("ingest accepted", fab.ingest(ff))
    assert_eq("no failures no dlq", fab.dlq_store.count(), 0)
    assert_true("dlq accessible", True)
}


# =============================================================================
# Scenarios — end-to-end flow engine behavior
# =============================================================================

def test_scenario_processor_chain() {
    print("--- Scenario: Processor Chain ---")
    ctx = test_scoped_context()
    reg = Registry()
    register_builtins(reg)
    tagger = reg.create("add-attribute", ctx, {"key": "env", "value": "dev"})
    logger = reg.create("log", ctx, {"prefix": "chain-test"})

    tag_queue = FlowQueue("tag-env", 100, 1024 * 1024, 30.0)
    log_queue = FlowQueue("logger", 100, 1024 * 1024, 30.0)
    queues = {"tag-env": tag_queue, "logger": log_queue}

    tag_engine = RulesEngine()
    tag_engine.add_or_replace_ruleset("flow", [RoutingRule("to-logger", "env", Operator.EXISTS, "", "logger")])
    log_engine = RulesEngine()

    dlq = DLQ()
    tag_session = ProcessSession(tag_queue, tagger, "tag-env", tag_engine, queues, dlq, 5)
    log_session = ProcessSession(log_queue, logger, "logger", log_engine, queues, dlq, 5)

    ff = create_flowfile(b"hello", {"type": "order"})
    tag_queue.offer(ff)
    assert_eq("tag queue has 1", tag_queue.visible_count(), 1)

    assert_true("tag session executed", tag_session.execute())
    assert_eq("tag queue empty", tag_queue.visible_count(), 0)
    assert_eq("log queue has 1", log_queue.visible_count(), 1)

    assert_true("log session executed", log_session.execute())
    assert_eq("log queue empty", log_queue.visible_count(), 0)
    assert_eq("no dlq entries", dlq.count(), 0)
}

def test_scenario_disable_processor() {
    print("--- Scenario: Disable/Enable Processor ---")
    ctx = test_context()
    reg = Registry()
    register_builtins(reg)
    fab = Fabric(reg, ctx)
    fab.add_processor("tagger", "add-attribute", {"key": "env", "value": "test"})
    assert_eq("initially enabled", fab.processor_states["tagger"], ComponentState.ENABLED)

    fab.disable_processor("tagger", 1)
    ff = create_flowfile(b"test", {"type": "test"})
    fab.ingest(ff)

    fab.enable_processor("tagger")
    assert_eq("re-enabled", fab.processor_states["tagger"], ComponentState.ENABLED)
}

def test_scenario_backpressure_propagation() {
    print("--- Scenario: Backpressure Propagation ---")
    small_queue = FlowQueue("small", 3, 1024, 30.0)
    downstream = FlowQueue("downstream", 3, 1024, 30.0)
    queues = {"small": small_queue, "downstream": downstream}

    engine = RulesEngine()
    engine.add_or_replace_ruleset("flow", [RoutingRule("forward", "type", Operator.EXISTS, "", "downstream")])

    proc = LogProcessor("bp-test")
    dlq = DLQ()
    session = ProcessSession(small_queue, proc, "small", engine, queues, dlq, 5)

    for _ in range(3) {
        downstream.offer(create_flowfile(b"fill", {"type": "x"}))
    }
    assert_false("downstream full", downstream.has_capacity())

    small_queue.offer(create_flowfile(b"blocked", {"type": "test"}))
    assert_true("session ran", session.execute())
    assert_eq("item back in small queue", small_queue.visible_count(), 1)
    entry = small_queue.claim()
    assert_eq("attempt incremented", entry.attempt_count, 1)
}

def test_scenario_retry_exhaustion_to_dlq() {
    print("--- Scenario: Retry Exhaustion -> DLQ ---")
    source = FlowQueue("source", 100, 1024 * 1024, 30.0)
    dest = FlowQueue("dest", 0, 0, 30.0)
    queues = {"dest": dest}

    engine = RulesEngine()
    engine.add_or_replace_ruleset("flow", [RoutingRule("to-dest", "type", Operator.EXISTS, "", "dest")])

    proc = LogProcessor("retry-test")
    dlq = DLQ()
    max_retries = 3
    session = ProcessSession(source, proc, "source", engine, queues, dlq, max_retries)

    ff = create_flowfile(b"will-fail", {"type": "test"})
    source.offer(ff)

    for _ in range(max_retries + 1) {
        session.execute()
    }

    assert_eq("dlq has entry", dlq.count(), 1)
    assert_eq("source queue empty", source.visible_count(), 0)
    entries = dlq.list_entries()
    assert_eq("dlq source processor", entries[0].source_processor, "source")
    assert_eq("dlq error", entries[0].last_error, "max retries exceeded")
}

def test_scenario_dlq_replay_to_source_queue() {
    print("--- Scenario: DLQ Replay to Source Queue ---")
    dlq = DLQ()
    source = FlowQueue("my-proc", 100, 1024 * 1024, 30.0)

    ff = create_flowfile(b"replay-test", {"type": "order"})
    dlq.add(ff, "my-proc", "my-proc", 5, "processing failed")
    assert_eq("dlq count", dlq.count(), 1)

    entries = dlq.list_entries()
    replayed = dlq.replay(entries[0].id)
    assert_eq("replayed ff id matches", replayed.id, ff.id)
    assert_eq("dlq empty after replay", dlq.count(), 0)

    source.offer(replayed)
    assert_eq("source queue has replayed item", source.visible_count(), 1)

    entry = source.claim()
    assert_eq("claimed replayed ff", entry.flowfile.id, ff.id)
    source.ack(entry.id)
    assert_eq("source queue empty after processing", source.visible_count(), 0)
}

def test_scenario_scoped_provider_isolation() {
    print("--- Scenario: Scoped Provider Isolation ---")
    cp = ContentProvider("content", None)
    cp.enable()
    lp = LoggingProvider()
    lp.enable()

    ctx = ScopedContext({"content": cp})
    p = ctx.get_provider("content")
    assert_eq("content provider type", p.get_type(), "content")
    assert_eq("only 1 provider in scope", len(ctx.list_providers()), 1)
}

def test_scenario_dependency_cascade() {
    print("--- Scenario: Dependency Cascade ---")
    cp = ContentProvider("content", None)
    cp.enable()
    global_ctx = ProcessorContext()
    global_ctx.add_provider(cp)
    global_ctx.register_dependent("content", "file-sink")

    reg = Registry()
    register_builtins(reg)
    fab = Fabric(reg, global_ctx)
    fab.add_processor("file-sink", "file-sink", {"output_dir": "/tmp/test"})
    assert_eq("sink initially enabled", fab.processor_states["file-sink"], ComponentState.ENABLED)

    fab.disable_provider("content", 1)
    assert_false("content provider disabled", cp.is_enabled())
    state = fab.processor_states["file-sink"]
    assert_true("sink draining or disabled after cascade", state == ComponentState.DRAINING or state == ComponentState.DISABLED)
}

def test_scenario_enable_refuses_disabled_provider() {
    print("--- Scenario: Enable Refuses Disabled Provider ---")
    cp = ContentProvider("content", None)
    # Leave disabled
    global_ctx = ProcessorContext()
    global_ctx.add_provider(cp)

    reg = Registry()
    register_builtins(reg)
    fab = Fabric(reg, global_ctx)
    fab.add_processor("sink", "file-sink", {"output_dir": "/tmp/test"})
    fab.processor_requires["sink"] = ["content"]

    fab.disable_processor("sink", 0)
    time.sleep(0.3)

    # Enable should fail — content provider is disabled
    assert_false("enable refused with disabled provider", fab.enable_processor("sink"))

    # Enable provider, then processor should succeed
    cp.enable()
    assert_true("enable succeeds with provider enabled", fab.enable_processor("sink"))
}

def test_scenario_irs_fan_out() {
    print("--- Scenario: IRS Fan-Out ---")
    tagger = AddAttribute("env", "prod")

    src = FlowQueue("source", 100, 1024 * 1024, 30.0)
    dest_a = FlowQueue("dest-a", 100, 1024 * 1024, 30.0)
    dest_b = FlowQueue("dest-b", 100, 1024 * 1024, 30.0)
    dest_c = FlowQueue("dest-c", 100, 1024 * 1024, 30.0)
    queues = {"source": src, "dest-a": dest_a, "dest-b": dest_b, "dest-c": dest_c}

    engine = RulesEngine()
    engine.add_or_replace_ruleset("flow", [
        RoutingRule("to-a", "env", Operator.EXISTS, "", "dest-a"),
        RoutingRule("to-b", "env", Operator.EXISTS, "", "dest-b"),
        RoutingRule("to-c", "env", Operator.EXISTS, "", "dest-c"),
    ])

    dlq = DLQ()
    session = ProcessSession(src, tagger, "source", engine, queues, dlq, 5)

    ff = create_flowfile(b"fanout", {"type": "order"})
    src.offer(ff)
    session.execute()

    assert_eq("dest-a has 1", dest_a.visible_count(), 1)
    assert_eq("dest-b has 1", dest_b.visible_count(), 1)
    assert_eq("dest-c has 1", dest_c.visible_count(), 1)
    assert_eq("source empty", src.visible_count(), 0)
    assert_eq("no dlq", dlq.count(), 0)

    entry_a = dest_a.claim()
    assert_eq("dest-a has env attr", entry_a.flowfile.attributes["env"], "prod")
    dest_a.ack(entry_a.id)
}

def test_scenario_visibility_timeout() {
    print("--- Scenario: Visibility Timeout ---")
    q = FlowQueue("vis-test", 10, 1024, 0.5)
    q.start_reaper()

    ff = create_flowfile(b"timeout-test", {"type": "test"})
    q.offer(ff)

    entry = q.claim()
    assert_true("claimed non-empty", entry is not None)
    assert_eq("visible after claim", q.visible_count(), 0)
    assert_eq("invisible after claim", q.invisible_count(), 1)
    assert_eq("attempt before timeout", entry.attempt_count, 0)

    time.sleep(2.0)

    assert_eq("visible after timeout", q.visible_count(), 1)
    assert_eq("invisible after timeout", q.invisible_count(), 0)

    reclaimed = q.claim()
    assert_true("reclaimed non-empty", reclaimed is not None)
    if reclaimed is not None {
        assert_eq("attempt after timeout", reclaimed.attempt_count, 1)
        q.ack(reclaimed.id)
    }
    assert_eq("clean after ack", q.visible_count(), 0)
}


# =============================================================================
# Main
# =============================================================================

def main() {
    print("=== zinc-flow-python test suite ===")
    print("")

    # Core types
    test_flowfile_basics()
    test_content_types()

    # Processors
    test_processor_add_attribute()
    test_processor_log_passthrough()
    test_processor_file_sink()
    test_processor_json_to_records()
    test_processor_records_to_json()
    test_processor_json_roundtrip()
    test_processor_json_to_records_empty()

    # Routing engine
    test_routing_eq()
    test_routing_neq()
    test_routing_contains()
    test_routing_starts_ends_with()
    test_routing_exists()
    test_routing_no_match()

    # Fabric integration
    test_fabric_multi_hop()
    test_fabric_dlq_from_failure()

    # Flow engine: queues, DLQ, sessions, providers
    test_queue_offer_claim()
    test_queue_backpressure()
    test_queue_ack_nack()
    test_dlq_add_and_list()
    test_dlq_replay()
    test_scoped_context_access()
    test_provider_lifecycle()

    # Scenarios
    test_scenario_processor_chain()
    test_scenario_disable_processor()
    test_scenario_backpressure_propagation()
    test_scenario_retry_exhaustion_to_dlq()
    test_scenario_dlq_replay_to_source_queue()
    test_scenario_scoped_provider_isolation()
    test_scenario_dependency_cascade()
    test_scenario_enable_refuses_disabled_provider()
    test_scenario_irs_fan_out()
    test_scenario_visibility_timeout()

    print("")
    print("=== {passed} passed, {failed} failed ===")
    if failed > 0 {
        sys.exit(1)
    }
}


# Entry point — `zinc-python run tests/test_flow.zn` executes this file
# as a script via `python test_flow.py`, which doesn't auto-call main().
main()
