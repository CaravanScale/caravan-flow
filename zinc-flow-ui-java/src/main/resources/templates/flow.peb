{% extends "templates/layout.peb" %}
{% block content %}
<h1>Flow</h1>
<p class="meta">Worker: <code>{{ workerUrl }}</code></p>

<div id="flow-cards"
     hx-get="{{ flowCardsUrl }}"
     hx-trigger="every 2s"
     hx-swap="innerHTML">
    {% include "templates/flow-cards.peb" %}
</div>
{% endblock %}
