#!/usr/bin/env bash
# zinc — thin CLI wrapper over dotnet for zinc-flow-csharp
# Reads zinc.toml, generates .csproj, delegates to dotnet.
#
# Usage:
#   ./zinc build          Build in Release mode
#   ./zinc run             Build + run
#   ./zinc test            Run tests
#   ./zinc publish         Native AOT publish (produces static binary)
#   ./zinc clean           Remove build artifacts
#   ./zinc csproj          Regenerate .csproj from zinc.toml (no build)
#   ./zinc bench           Build + run benchmarks in Release mode

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PROJECT_DIR="$SCRIPT_DIR/ZincFlow"
ZINC_TOML="$SCRIPT_DIR/zinc.toml"
CSPROJ="$PROJECT_DIR/ZincFlow.csproj"
BUILD_DIR="$SCRIPT_DIR/build"

# --- TOML parser (minimal, handles our zinc.toml structure) ---

toml_get() {
    # toml_get <file> <section> <key> [default]
    local file="$1" section="$2" key="$3" default="${4:-}"
    local in_section=false value=""

    while IFS= read -r line; do
        # Strip comments and whitespace
        line="${line%%#*}"
        line="${line#"${line%%[![:space:]]*}"}"
        line="${line%"${line##*[![:space:]]}"}"
        [ -z "$line" ] && continue

        # Section header
        if [[ "$line" =~ ^\[([a-zA-Z0-9_.]+)\]$ ]]; then
            [[ "${BASH_REMATCH[1]}" == "$section" ]] && in_section=true || in_section=false
            continue
        fi

        # Key = value (in target section)
        if $in_section && [[ "$line" =~ ^([a-zA-Z_]+)[[:space:]]*=[[:space:]]*(.+)$ ]]; then
            local k="${BASH_REMATCH[1]}" v="${BASH_REMATCH[2]}"
            # Strip quotes
            v="${v%\"}" ; v="${v#\"}"
            v="${v%\'}" ; v="${v#\'}"
            if [[ "$k" == "$key" ]]; then
                value="$v"
            fi
        fi
    done < "$file"

    echo "${value:-$default}"
}

toml_bool() {
    local val
    val="$(toml_get "$@")"
    [[ "$val" == "true" ]] && echo "true" || echo "false"
}

# --- .csproj generator ---

generate_csproj() {
    local framework lang_version nullable implicit_usings unsafe
    local server_gc aot strip invariant opt stack_traces trim_metadata

    framework="$(toml_get "$ZINC_TOML" "csharp" "framework" "net10.0")"
    lang_version="$(toml_get "$ZINC_TOML" "csharp" "lang_version" "latest")"
    nullable="$(toml_bool "$ZINC_TOML" "csharp" "nullable" "true")"
    implicit_usings="$(toml_bool "$ZINC_TOML" "csharp" "implicit_usings" "true")"
    unsafe="$(toml_bool "$ZINC_TOML" "csharp" "unsafe" "false")"

    server_gc="$(toml_bool "$ZINC_TOML" "csharp.gc" "server" "true")"

    aot="$(toml_bool "$ZINC_TOML" "csharp.aot" "enabled" "false")"
    strip="$(toml_bool "$ZINC_TOML" "csharp.aot" "strip_symbols" "true")"
    invariant="$(toml_bool "$ZINC_TOML" "csharp.aot" "invariant_globalization" "true")"
    opt="$(toml_get "$ZINC_TOML" "csharp.aot" "optimization" "Size")"
    stack_traces="$(toml_bool "$ZINC_TOML" "csharp.aot" "stack_traces" "false")"
    trim_metadata="$(toml_bool "$ZINC_TOML" "csharp.aot" "trim_metadata" "true")"

    mkdir -p "$PROJECT_DIR"

    cat > "$CSPROJ" <<CSPROJ_EOF
<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework>${framework}</TargetFramework>
    <LangVersion>${lang_version}</LangVersion>
    <Nullable>$([ "$nullable" = "true" ] && echo "enable" || echo "disable")</Nullable>
    <ImplicitUsings>$([ "$implicit_usings" = "true" ] && echo "enable" || echo "disable")</ImplicitUsings>
    <AllowUnsafeBlocks>${unsafe}</AllowUnsafeBlocks>
    <ServerGarbageCollection>${server_gc}</ServerGarbageCollection>
  </PropertyGroup>

CSPROJ_EOF

    # AOT section (only if enabled)
    if [[ "$aot" == "true" ]]; then
        cat >> "$CSPROJ" <<AOT_EOF
  <!-- Native AOT -->
  <PropertyGroup>
    <PublishAot>true</PublishAot>
    <StripSymbols>${strip}</StripSymbols>
    <InvariantGlobalization>${invariant}</InvariantGlobalization>
    <IlcOptimizationPreference>${opt}</IlcOptimizationPreference>
    <IlcGenerateStackTraceData>${stack_traces}</IlcGenerateStackTraceData>
    <StackTraceSupport>${stack_traces}</StackTraceSupport>
    <UseSystemResourceKeys>$([ "$trim_metadata" = "true" ] && echo "true" || echo "false")</UseSystemResourceKeys>
    <IlcTrimMetadata>${trim_metadata}</IlcTrimMetadata>
  </PropertyGroup>

AOT_EOF
    fi

    echo "</Project>" >> "$CSPROJ"
}

# --- Commands ---

cmd_csproj() {
    generate_csproj
    echo "Generated $CSPROJ from zinc.toml"
}

cmd_build() {
    generate_csproj
    export PATH="$HOME/.dotnet:$PATH"
    dotnet build "$PROJECT_DIR" -c Release
}

cmd_run() {
    generate_csproj
    export PATH="$HOME/.dotnet:$PATH"
    dotnet run --project "$PROJECT_DIR" -c Release
}

cmd_bench() {
    cmd_run
}

cmd_test() {
    generate_csproj
    export PATH="$HOME/.dotnet:$PATH"
    dotnet test "$PROJECT_DIR" -c Release
}

cmd_publish() {
    generate_csproj
    export PATH="$HOME/.dotnet:$PATH"

    local rid="${1:-linux-x64}"
    mkdir -p "$BUILD_DIR"

    echo "Publishing AOT binary for $rid..."
    dotnet publish "$PROJECT_DIR" -c Release -r "$rid" -o "$BUILD_DIR"

    local binary="$BUILD_DIR/ZincFlow"
    if [[ -f "$binary" ]]; then
        local size
        size=$(du -h "$binary" | cut -f1)
        echo ""
        echo "Binary: $binary ($size)"
        file "$binary"
    fi
}

cmd_clean() {
    rm -rf "$PROJECT_DIR/bin" "$PROJECT_DIR/obj" "$BUILD_DIR"
    echo "Cleaned build artifacts"
}

cmd_help() {
    cat <<HELP
zinc — build tool for zinc-flow-csharp

Commands:
  build       Build in Release mode
  run         Build + run (benchmarks)
  bench       Alias for run
  publish     Native AOT publish (default: linux-x64)
              ./zinc publish linux-arm64
  test        Run tests
  csproj      Regenerate .csproj from zinc.toml
  clean       Remove build artifacts
  help        Show this help

Config:  zinc.toml
Project: ZincFlow/ZincFlow.csproj (generated — do not edit)
HELP
}

# --- Main ---

if [[ ! -f "$ZINC_TOML" ]]; then
    echo "Error: zinc.toml not found in $SCRIPT_DIR" >&2
    exit 1
fi

CMD="${1:-help}"
shift 2>/dev/null || true

case "$CMD" in
    build)   cmd_build "$@" ;;
    run)     cmd_run "$@" ;;
    bench)   cmd_bench "$@" ;;
    test)    cmd_test "$@" ;;
    publish) cmd_publish "$@" ;;
    clean)   cmd_clean "$@" ;;
    csproj)  cmd_csproj "$@" ;;
    help|-h|--help) cmd_help ;;
    *)
        echo "Unknown command: $CMD" >&2
        cmd_help >&2
        exit 1
        ;;
esac
